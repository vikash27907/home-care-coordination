<%- include("../partials/head", { title }) %>
<link rel="stylesheet" href="/css/agent-dashboard.css">

<div class="agent-dashboard" id="agentDashboard" data-agent-email="<%= currentUser && currentUser.email ? currentUser.email : '' %>">
  <aside class="agent-sidebar">
    <div class="agent-sidebar__brand">
      <h1>Agent Dashboard</h1>
      <p>Operations Console</p>
    </div>
    <nav class="agent-sidebar__nav" aria-label="Agent sections">
      <a href="#overview" class="is-active" data-nav-link>Overview</a>
      <a href="/agent/profile">Profile</a>
      <a href="#requests" data-nav-link>Requests</a>
      <a href="#applications" data-nav-link>Applications</a>
      <a href="#nurses" data-nav-link>Nurses</a>
      <a href="#financials" data-nav-link>Financials</a>
      <a href="#patients" data-nav-link>Patients</a>
      <a href="#agents" data-nav-link>Agents</a>
      <a href="#reports" data-nav-link>Reports</a>
    </nav>
    <div class="agent-sidebar__meta">
      <p><strong>Logged in:</strong> <%= currentUser.email %></p>
      <% if (agent && agent.status && agent.status !== "approved") { %>
        <p class="pending-badge">Status: <%= agent.status %></p>
      <% } %>
    </div>
  </aside>

  <section class="agent-main">
    <header class="agent-header">
      <div>
        <h2>Control Panel</h2>
        <p>Build flow: UI -> Mock -> API -> Live Data.</p>
      </div>
      <div class="agent-header__actions">
        <input type="search" id="requestSearch" placeholder="Search requests, city, care type" aria-label="Search requests">
      </div>
    </header>

    <% if (agent && agent.status && agent.status !== "approved") { %>
      <section class="agent-alert" aria-live="polite">
        Profile approval is pending. Dashboard is visible; restricted actions may require approval.
      </section>
    <% } %>

    <section id="overview" class="panel">
      <div class="panel-heading">
        <h3>Overview</h3>
      </div>
      <div class="stats-grid">
        <article class="stat-card">
          <span>Pending Requests</span>
          <strong id="statPendingRequests">0</strong>
        </article>
        <article class="stat-card">
          <span>Active Jobs</span>
          <strong id="statActiveJobs">0</strong>
        </article>
        <article class="stat-card">
          <span>Available Nurses</span>
          <strong id="statAvailableNurses">0</strong>
        </article>
        <article class="stat-card">
          <span>Revenue</span>
          <strong id="statRevenue">INR 0</strong>
        </article>
      </div>
      <div class="chart-card">
        <div class="panel-heading panel-heading--compact">
          <h4>Monthly Performance</h4>
          <small>Revenue / Completed Jobs / Active Nurses</small>
        </div>
        <div id="monthlyChart" class="mini-chart" aria-label="Monthly performance chart"></div>
      </div>
    </section>

    <section id="requests" class="panel">
      <div class="panel-heading">
        <h3>Care Requests</h3>
      </div>
      <div class="filters-row">
        <select id="cityFilter" aria-label="Filter by city">
          <option value="all">All Cities</option>
        </select>
        <select id="careTypeFilter" aria-label="Filter by care type">
          <option value="all">All Care Types</option>
        </select>
        <select id="statusFilter" aria-label="Filter by status">
          <option value="all">All Status</option>
        </select>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Patient</th>
              <th>City</th>
              <th>Care Type</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="requestsTableBody"></tbody>
        </table>
      </div>
    </section>

    <section id="applications" class="panel">
      <div class="panel-heading">
        <h3>Nurse Applications</h3>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Application</th>
              <th>Request</th>
              <th>Nurse</th>
              <th>City</th>
              <th>Care Type</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="applicationsTableBody"></tbody>
        </table>
      </div>
    </section>

    <section id="nurses" class="panel">
      <div class="panel-heading">
        <h3>My Nurses</h3>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>City</th>
              <th>Experience</th>
              <th>Availability</th>
              <th>Status</th>
              <th>Active Jobs</th>
            </tr>
          </thead>
          <tbody id="nursesTableBody"></tbody>
        </table>
      </div>
    </section>

    <section id="financials" class="panel">
      <div class="panel-heading">
        <h3>Financial Summary</h3>
      </div>
      <div class="finance-grid">
        <article class="finance-card">
          <span>Gross Amount</span>
          <strong id="grossAmount">INR 0</strong>
        </article>
        <article class="finance-card">
          <span>Platform Fee</span>
          <strong id="platformFee">INR 0</strong>
        </article>
        <article class="finance-card">
          <span>Agent Margin</span>
          <strong id="agentMargin">INR 0</strong>
        </article>
        <article class="finance-card">
          <span>Nurse Payout</span>
          <strong id="nursePayout">INR 0</strong>
        </article>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Request</th>
              <th>Patient</th>
              <th>Nurse</th>
              <th>Gross</th>
              <th>Platform Fee</th>
              <th>Net / Payout</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="financialTableBody"></tbody>
        </table>
      </div>
    </section>

    <section id="patients" class="panel panel-placeholder">
      <div class="panel-heading">
        <h3>Patients</h3>
      </div>
      <p>Planned for Phase 10 production scope.</p>
    </section>

    <section id="agents" class="panel panel-placeholder">
      <div class="panel-heading">
        <h3>Agents</h3>
      </div>
      <p>Planned for Phase 10 production scope.</p>
    </section>

    <section id="reports" class="panel panel-placeholder">
      <div class="panel-heading">
        <h3>Reports</h3>
      </div>
      <p>Planned for Phase 10 production scope.</p>
    </section>

    <section class="panel">
      <div class="panel-heading">
        <h3>Operational Feed</h3>
      </div>
      <ul id="actionFeed" class="feed-list"></ul>
    </section>
  </section>
</div>

<script src="/js/agent-dashboard.js"></script>
<%- include("../partials/footer") %>
