<%- include("../partials/head", { title }) %>
<link rel="stylesheet" href="/css/agent-dashboard-tabs.css">

<section class="agent-hub container py-4">
  <div class="agent-hub__header mb-4">
    <div>
      <p class="agent-hub__eyebrow">Operations Console</p>
      <h1>Agent Dashboard</h1>
      <p class="agent-hub__intro">Manage care requests and your nurse roster from one unified dashboard.</p>
    </div>
    <% if (agent && agent.status && agent.status !== "approved") { %>
      <span class="badge bg-secondary">Status: <%= agent.status %></span>
    <% } %>
  </div>

  <ul class="nav nav-pills mb-4" aria-label="Agent dashboard tabs">
    <li class="nav-item">
      <a
        class="nav-link <%= activeTab === 'jobs' ? 'active' : '' %>"
        href="/agent/dashboard?tab=jobs"
      >
        My Jobs
      </a>
    </li>
    <li class="nav-item">
      <a
        class="nav-link <%= activeTab === 'staff' ? 'active' : '' %>"
        href="/agent/dashboard?tab=staff"
      >
        My Staff
      </a>
    </li>
  </ul>

  <% if (activeTab === "jobs") { %>
    <div class="section-head d-flex justify-content-between align-items-center mb-3">
      <div>
        <h2>Patient Requests</h2>
        <p class="text-muted">Current care requests mapped to your account.</p>
      </div>
      <a href="/request-care" class="btn btn-primary">+ Add Job</a>
    </div>

    <div class="row g-3">
      <% if (!jobs.length) { %>
        <div class="col-12">
          <div class="empty-state">No jobs added yet.</div>
        </div>
      <% } else { %>
        <% jobs.forEach((job) => { %>
          <div class="col-12 col-md-6">
            <article class="card shadow-sm h-100">
              <div class="card-body">
                <div class="card-copy">
                  <h3 class="card-title"><%= job.patient_name %></h3>
                  <p class="text-muted mb-1"><strong>Service:</strong> <%= job.service_required %></p>
                  <p class="text-muted mb-1">ID: <%= job.request_code %></p>
                  <p class="text-muted mb-2"><strong>City:</strong> <%= job.address %></p>
                  <span class="badge bg-secondary"><%= job.status %></span>
                </div>
                <% if (!job.assigned_nurse_id) { %>
                  <% if (assignableNurses && assignableNurses.length) { %>
                    <form method="POST" action="/agent/requests/<%= job.id %>/actions" class="assign-form">
                      <input type="hidden" name="action" value="assign" />
                      <label class="assign-form__label" for="nurse-<%= job.id %>">Assign Nurse</label>
                      <select id="nurse-<%= job.id %>" name="nurseId" class="assign-form__select" required>
                        <option value="">Select a nurse</option>
                        <% assignableNurses.forEach((nurse) => { %>
                          <option value="<%= nurse.id %>"><%= nurse.full_name %> (<%= nurse.unique_id %>)</option>
                        <% }) %>
                      </select>
                      <button type="submit" class="btn btn-primary btn-sm">Assign Nurse</button>
                    </form>
                  <% } else { %>
                    <p class="text-muted mb-0">No available nurses in your roster right now.</p>
                  <% } %>
                <% } else { %>
                  <div class="assigned-note">
                    <span class="badge bg-secondary">Assigned</span>
                    <p class="text-muted mb-0"><strong>Nurse:</strong> <%= job.assigned_nurse_name %></p>
                  </div>
                <% } %>
              </div>
            </article>
          </div>
        <% }) %>
      <% } %>
    </div>
  <% } %>

  <% if (activeTab === "staff") { %>
    <div class="section-head d-flex justify-content-between align-items-center mb-3">
      <div>
        <h2>Your Nurses</h2>
        <p class="text-muted">Only nurses mapped to your account are shown here.</p>
      </div>
      <a href="/nurse/register?ref_agent=<%= user && user.id ? user.id : '' %>" class="btn btn-primary">+ Add Nurse</a>
    </div>

    <div class="nurse-cards-grid">
      <% if (!staff.length) { %>
        <div class="empty-state">No nurses added yet.</div>
      <% } else { %>
        <% staff.forEach((nurse) => { %>
          <%- include("../partials/nurse-directory-card", {
            nurse,
            href: nurse.publicUrl,
            showRequestButton: false,
            showStatus: true
          }) %>
        <% }) %>
      <% } %>
    </div>
  <% } %>
</section>

<%- include("../partials/footer") %>
