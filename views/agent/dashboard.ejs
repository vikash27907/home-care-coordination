<%- include("../partials/head", { title, extraStylesheets: ["/css/agent-dashboard-tabs.css"] }) %>

<%
  function icon(name, className = "") {
    const cls = className ? ` class="${className}"` : "";
    const icons = {
      dashboard: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 5.5A1.5 1.5 0 015.5 4h4A1.5 1.5 0 0111 5.5v4A1.5 1.5 0 019.5 11h-4A1.5 1.5 0 014 9.5v-4zM13 5.5A1.5 1.5 0 0114.5 4h4A1.5 1.5 0 0120 5.5v7A1.5 1.5 0 0118.5 14h-4a1.5 1.5 0 01-1.5-1.5v-7zM4 14.5A1.5 1.5 0 015.5 13h4A1.5 1.5 0 0111 14.5v4A1.5 1.5 0 019.5 20h-4A1.5 1.5 0 014 18.5v-4zM13 17.5A1.5 1.5 0 0114.5 16h4A1.5 1.5 0 0120 17.5v1A1.5 1.5 0 0118.5 20h-4a1.5 1.5 0 01-1.5-1.5v-1z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>`,
      jobs: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="4" y="6" width="16" height="13" rx="3" stroke="currentColor" stroke-width="1.7"/><path d="M9 6V5.2A1.2 1.2 0 0110.2 4h3.6A1.2 1.2 0 0115 5.2V6M4 11.5h16" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>`,
      staff: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="9" cy="8" r="3" stroke="currentColor" stroke-width="1.7"/><circle cx="16.5" cy="9.5" r="2.5" stroke="currentColor" stroke-width="1.7"/><path d="M4.5 18a4.5 4.5 0 019 0M13.5 18a3 3 0 016 0" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>`,
      profile: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="3.2" stroke="currentColor" stroke-width="1.7"/><path d="M5.5 19a6.5 6.5 0 0113 0" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>`,
      condition: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 12h3.5l1.7-3.6L12 16l2.1-4h5.9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 21a9 9 0 100-18 9 9 0 000 18z" stroke="currentColor" stroke-width="1.4" opacity=".22"/></svg>`,
      location: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s6-5.7 6-10.8a6 6 0 10-12 0C6 15.3 12 21 12 21z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.1" stroke="currentColor" stroke-width="1.7"/></svg>`,
      timing: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.7"/><path d="M12 7.8v4.6l3 1.8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
      salary: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3.5" y="6.5" width="17" height="11" rx="2.5" stroke="currentColor" stroke-width="1.7"/><path d="M8.5 12h7M12 9v6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>`,
      phone: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7.3 4.7l2.2 3.8-1.4 1.8a14.5 14.5 0 005.4 5.4l1.8-1.4 3.8 2.2-1.2 3.7a2 2 0 01-2.2 1.3A18.5 18.5 0 013.7 8.1a2 2 0 011.3-2.2l2.3-1.2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
      payment: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 7h10M7 12h7M7 17h5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><rect x="4" y="4" width="16" height="16" rx="3" stroke="currentColor" stroke-width="1.7"/></svg>`,
      assign: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="8.5" cy="9" r="2.5" stroke="currentColor" stroke-width="1.7"/><path d="M4.5 18a4 4 0 018 0M15 8.5h5M17.5 6v5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>`,
      edit: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20h4l9.6-9.6a1.8 1.8 0 000-2.5l-1.5-1.5a1.8 1.8 0 00-2.5 0L4 16v4z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M12.5 7.5l4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>`,
      delete: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 7h14M9 7V5.8A1.8 1.8 0 0110.8 4h2.4A1.8 1.8 0 0115 5.8V7M7 7l.7 11.1A2 2 0 009.7 20h4.6a2 2 0 002-1.9L17 7" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
      open: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14 5h5v5M10 14l9-9M19 13v5a1 1 0 01-1 1H6a1 1 0 01-1-1V6a1 1 0 011-1h5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
      close: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/></svg>`
    };

    return icons[name] || icons.dashboard;
  }
%>

<section class="agent-hub container py-4" data-agent-dashboard>
  <ul class="nav nav-pills mb-4 agent-dashboard-tabs" aria-label="Agent dashboard tabs">
    <li class="nav-item">
      <a class="nav-link <%= activeTab === 'staff' ? 'active' : '' %>" href="/agent/dashboard?tab=staff">
        <span class="agent-tab-icon"><%- icon("staff") %></span>
        <span>Staff</span>
      </a>
    </li>
    <li class="nav-item">
      <a class="nav-link <%= activeTab === 'jobs' ? 'active' : '' %>" href="/agent/dashboard?tab=jobs">
        <span class="agent-tab-icon"><%- icon("jobs") %></span>
        <span>Jobs</span>
      </a>
    </li>
  </ul>

  <% if (activeTab === "jobs") { %>
    <div class="section-head agent-section-head mb-3" data-reveal>
      <div class="agent-section-head__copy">
        <span class="agent-section-head__icon"><%- icon("jobs") %></span>
        <div>
          <h1 class="h3 mb-0">Jobs</h1>
        </div>
      </div>
      <a href="/agent/jobs/new" class="btn btn-primary">+ Add Job</a>
    </div>

    <div class="agent-job-grid">
      <% if (!jobs.length) { %>
        <div class="empty-state agent-empty-state">
          <h3>No jobs yet</h3>
          <p>Create your first care request and assign from your approved nurse roster.</p>
          <a href="/agent/jobs/new" class="btn btn-primary">Create Job</a>
        </div>
      <% } else { %>
        <% jobs.forEach((job) => { %>
          <%
            const jobTiming = [job.service_schedule, job.duration].filter(Boolean).join(" / ") || "-";
            const approvalState = String(job.visibility_status || "").toLowerCase();
          %>
          <article class="agent-job-card card shadow-sm" data-reveal>
            <div class="agent-job-card__top">
              <div class="agent-job-card__headline">
                <span class="agent-job-card__icon"><%- icon("jobs") %></span>
                <div>
                  <h3><%= job.service_required %></h3>
                  <p><strong><%= job.patient_name %></strong> <span aria-hidden="true">&middot;</span> <%= job.request_code %></p>
                </div>
              </div>

              <div class="agent-job-card__top-side">
                <div class="agent-job-card__badges">
                  <span class="status-pill <%= approvalState === 'approved' ? 'status-pill--success' : (approvalState === 'rejected' ? 'status-pill--danger' : 'status-pill--warning') %>">
                    Approval: <%= job.visibility_status || "pending" %>
                  </span>
                  <span class="status-pill status-pill--neutral">Status: <%= job.status %></span>
                </div>

                <div class="agent-card-toolbar" aria-label="Job quick actions">
                  <% if (job.canEdit) { %>
                    <a
                      href="/agent/jobs/<%= job.id %>/edit"
                      class="agent-icon-button"
                      aria-label="Edit job"
                      title="Edit job"
                      data-card-action
                    >
                      <%- icon("edit") %>
                    </a>
                  <% } %>

                  <% if (job.canDelete) { %>
                    <form method="POST" action="/agent/jobs/<%= job.id %>/delete" class="agent-inline-form" data-card-action onsubmit="return confirm('Delete this job?');">
                      <button type="submit" class="agent-icon-button agent-icon-button--danger" aria-label="Delete job" title="Delete job">
                        <%- icon("delete") %>
                      </button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>

            <div class="agent-job-card__quick-grid" aria-label="Job summary">
              <div class="agent-info-tile">
                <span class="agent-info-tile__icon"><%- icon("condition") %></span>
                <small>Condition</small>
                <strong><%= job.service_required || "-" %></strong>
              </div>
              <div class="agent-info-tile">
                <span class="agent-info-tile__icon"><%- icon("location") %></span>
                <small>Location</small>
                <strong><%= job.address || "-" %></strong>
              </div>
              <div class="agent-info-tile">
                <span class="agent-info-tile__icon"><%- icon("timing") %></span>
                <small>Timing</small>
                <strong><%= jobTiming %></strong>
              </div>
              <div class="agent-info-tile">
                <span class="agent-info-tile__icon"><%- icon("salary") %></span>
                <small>Salary</small>
                <strong>Rs. <%= Number(job.budget || 0).toLocaleString("en-IN") %></strong>
              </div>
            </div>

            <div class="agent-job-card__meta">
              <span><span class="agent-job-card__meta-icon"><%- icon("phone") %></span><strong>Phone:</strong> <%= job.patient_phone || "-" %></span>
              <span><span class="agent-job-card__meta-icon"><%- icon("payment") %></span><strong>Payment:</strong> <%= job.payment_status || "pending" %></span>
            </div>

            <% if (job.notes) { %>
              <p class="agent-job-card__notes"><%= job.notes %></p>
            <% } %>

            <% if (job.assigned_nurse_id) { %>
              <div class="agent-job-card__assignment">
                <span class="status-pill status-pill--success">Assigned Nurse</span>
                <p><strong><%= job.assigned_nurse_name %></strong> <%= job.assigned_nurse_code ? `(${job.assigned_nurse_code})` : "" %></p>
              </div>
            <% } %>

            <div class="agent-job-card__actions">
              <% if (job.canAssign) { %>
                <% if (assignableNurses && assignableNurses.length) { %>
                  <form method="POST" action="/agent/requests/<%= job.id %>/actions" class="assign-form agent-inline-form" data-inline-submit data-inline-label="Assigning nurse">
                    <input type="hidden" name="action" value="assign" />
                    <label class="assign-form__label" for="nurse-<%= job.id %>">
                      <span class="assign-form__label-icon"><%- icon("assign") %></span>
                      <span>Assign Nurse</span>
                    </label>
                    <select id="nurse-<%= job.id %>" name="nurseId" class="assign-form__select" required>
                      <option value="">Select a nurse</option>
                      <% assignableNurses.forEach((nurse) => { %>
                        <option value="<%= nurse.id %>"><%= nurse.full_name %> (<%= nurse.unique_id %>)</option>
                      <% }) %>
                    </select>
                    <button type="submit" class="btn btn-primary btn-sm">Assign Nurse</button>
                  </form>
                <% } else { %>
                  <p class="text-muted mb-0">No approved and available nurses are ready in your roster.</p>
                <% } %>
              <% } %>

              <div class="agent-job-card__action-row">
                <% if (job.canStart) { %>
                  <form method="POST" action="/agent/requests/<%= job.id %>/actions" class="agent-inline-form" data-inline-submit data-inline-label="Starting job">
                    <input type="hidden" name="action" value="start" />
                    <button type="submit" class="btn btn-success btn-sm">Start Job</button>
                  </form>
                <% } %>

                <% if (job.canComplete) { %>
                  <form method="POST" action="/agent/requests/<%= job.id %>/actions" class="agent-inline-form" data-inline-submit data-inline-label="Completing job">
                    <input type="hidden" name="action" value="complete" />
                    <button type="submit" class="btn btn-success btn-sm">Complete Job</button>
                  </form>
                <% } %>

                <% if (job.canEdit) { %>
                  <a href="/agent/jobs/<%= job.id %>/edit" class="btn btn-secondary btn-sm">Edit Job</a>
                <% } %>
              </div>
            </div>
          </article>
        <% }) %>
      <% } %>
    </div>
  <% } %>

  <% if (activeTab === "staff") { %>
    <div class="section-head agent-section-head mb-3" data-reveal>
      <div class="agent-section-head__copy">
        <span class="agent-section-head__icon"><%- icon("staff") %></span>
        <div>
          <h1 class="h3 mb-0">Staff</h1>
        </div>
      </div>
      <a href="/agent/nurses/new" class="btn btn-primary">+ Add Nurse</a>
    </div>

    <div class="nurse-cards-grid">
      <% if (!staff.length) { %>
        <div class="empty-state agent-empty-state">
          <h3>No nurses added yet</h3>
          <p>Add your first nurse and track approval progress here.</p>
          <a href="/agent/nurses/new" class="btn btn-primary">Add Nurse</a>
        </div>
      <% } else { %>
        <% staff.forEach((nurse) => { %>
          <%- include("../partials/nurse-directory-card", {
            nurse,
            href: nurse.dashboardUrl,
            shareUrl: nurse.publicUrl,
            mode: "compact",
            showRequestButton: false,
            showStatus: false,
            showUtilityButtons: true,
            cardHref: nurse.dashboardUrl,
            editHref: "",
            shareCardEnabled: true,
            shareCardProfileUrl: nurse.publicUrl,
            shareCardContactContext: nurse.contactContext
          }) %>
        <% }) %>
      <% } %>
    </div>
  <% } %>
</section>

<script src="/vendor/html-to-image.js"></script>
<script src="/js/agent-dashboard.js"></script>
<%- include("../partials/footer") %>
