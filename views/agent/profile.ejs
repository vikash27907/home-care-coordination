<%- include("../partials/head", { title, extraStylesheets: ["/css/agent-profile.css"] }) %>
<%
  const agentProfileImage = (agent && agent.profileImageUrl)
    || (session && session.user && session.user.profileImageUrl)
    || "/images/default-avatar.png";
  const agentAadhaarDoc = String((agent && (agent.aadhaarDocUrl || agent.aadhaarUrl)) || "").trim();
  const agentAadhaarDocIsImage = /\.(png|jpe?g|webp)(\?.*)?$/i.test(agentAadhaarDoc);
  const agentAadhaarDocIsPdf = /\.pdf(\?.*)?$/i.test(agentAadhaarDoc);
%>

<section class="agent-profile" data-agent-profile>
  <div class="cover" data-reveal>
    <img src="/images/patient-care.svg" alt="Agent cover" />
  </div>

  <div class="profile-header" data-reveal>
    <div class="avatar">
      <img src="<%= agentProfileImage %>" alt="Agent avatar" data-agent-avatar />
    </div>

    <div class="profile-info">
      <p class="agent-profile__eyebrow">Agent Profile</p>
      <h1><%= (agent && agent.fullName) || "Agent" %></h1>
      <p><%= (agent && agent.companyName) || "Healthcare Staffing Partner" %></p>

      <div class="profile-meta">
        <span>Region: <strong><%= (agent && (agent.workingRegion || agent.region)) || "Not shared" %></strong></span>
        <span>Phone: <strong><%= (agent && agent.phoneNumber) || "Not shared" %></strong></span>
        <span>Status: <strong><%= (agent && agent.status) || "pending" %></strong></span>
      </div>

      <div class="profile-actions">
        <% if (agent && agent.phoneNumber) { %>
          <a class="btn btn-primary" href="tel:+91<%= String(agent.phoneNumber).replace(/\D/g, '') %>">Call</a>
        <% } %>
        <button class="btn btn-secondary" type="button" data-agent-share="<%= profileShareUrl || '' %>">Share</button>
        <button class="btn btn-outline-primary" type="button" id="agentProfileEditToggle">Edit Profile</button>
      </div>
    </div>
  </div>

  <div class="stats" data-reveal>
    <div class="stat">
      <h3><%= stats && typeof stats.nursesManaged !== "undefined" ? stats.nursesManaged : 0 %></h3>
      <p>Nurses Managed</p>
    </div>
    <div class="stat">
      <h3><%= stats && typeof stats.completedJobs !== "undefined" ? stats.completedJobs : 0 %></h3>
      <p>Completed Jobs</p>
    </div>
    <div class="stat">
      <h3><%= stats && typeof stats.approvedNurses !== "undefined" ? stats.approvedNurses : 0 %></h3>
      <p>Approved Nurses</p>
    </div>
  </div>

  <form class="agent-profile-form profile-section" method="POST" action="/agent/profile/update" id="agentProfileForm" data-reveal enctype="multipart/form-data">
    <div class="agent-profile-form__header">
      <div>
        <h2>Profile Details</h2>
        <p>Update your public-facing coordination details. Changes reflect immediately after saving.</p>
      </div>
      <div class="agent-profile-form__badges">
        <span class="agent-mini-stat">Pending Nurses: <strong><%= stats && typeof stats.pendingNurses !== "undefined" ? stats.pendingNurses : 0 %></strong></span>
        <span class="agent-mini-stat">Rejected Nurses: <strong><%= stats && typeof stats.rejectedNurses !== "undefined" ? stats.rejectedNurses : 0 %></strong></span>
      </div>
    </div>

    <div class="agent-upload-grid agent-profile-form__span-2">
      <section class="agent-upload-card">
        <div class="agent-upload-card__copy">
          <p class="agent-upload-card__eyebrow">Profile Image</p>
          <h3>Photo shown across your account</h3>
          <p>Upload a clear square image. JPG, PNG, or WEBP up to 2MB.</p>
        </div>

        <div
          class="agent-upload-preview agent-upload-preview--avatar"
          data-preview-shell="profileImage"
          data-preview-type="image"
          data-initial-src="<%= agentProfileImage %>"
        >
          <img
            src="<%= agentProfileImage %>"
            alt="Agent profile preview"
            class="agent-upload-preview__image"
            data-preview-image="profileImage"
            data-agent-avatar
          />
        </div>

        <div class="agent-upload-card__actions">
          <button
            type="button"
            class="btn btn-outline-primary"
            data-file-trigger="profileImageInput"
          >
            <%= agent && agent.profileImageUrl ? "Change Image" : "Upload Image" %>
          </button>
          <span class="agent-upload-card__status" data-file-name="profileImage">
            <%= agent && agent.profileImageUrl ? "Current image uploaded." : "No profile image uploaded yet." %>
          </span>
        </div>

        <input
          id="profileImageInput"
          type="file"
          name="profileImage"
          accept="image/jpeg,image/png,image/webp"
          hidden
          data-file-input="profileImage"
        />
      </section>

      <section class="agent-upload-card">
        <div class="agent-upload-card__copy">
          <p class="agent-upload-card__eyebrow">Aadhaar / Document</p>
          <h3>Identity document preview and replacement</h3>
          <p>Upload JPG, PNG, WEBP, or PDF up to 4MB. Existing file stays visible until you replace it.</p>
        </div>

        <div
          class="agent-upload-preview agent-upload-preview--document"
          data-preview-shell="aadhaarDoc"
          data-preview-type="<%= agentAadhaarDocIsPdf ? 'pdf' : (agentAadhaarDocIsImage ? 'image' : 'empty') %>"
          data-initial-src="<%= agentAadhaarDoc %>"
        >
          <% if (agentAadhaarDoc && agentAadhaarDocIsImage) { %>
            <img
              src="<%= agentAadhaarDoc %>"
              alt="Uploaded Aadhaar document"
              class="agent-upload-preview__image agent-upload-preview__image--document"
              data-preview-image="aadhaarDoc"
            />
          <% } else if (agentAadhaarDoc && agentAadhaarDocIsPdf) { %>
            <iframe
              src="<%= agentAadhaarDoc %>"
              title="Uploaded Aadhaar document preview"
              class="agent-upload-preview__frame"
              data-preview-frame="aadhaarDoc"
            ></iframe>
          <% } else { %>
            <div class="agent-upload-preview__empty" data-preview-empty="aadhaarDoc">
              <strong>No document uploaded</strong>
              <span>Your Aadhaar or ID file preview will appear here.</span>
            </div>
          <% } %>
        </div>

        <div class="agent-upload-card__actions">
          <button
            type="button"
            class="btn btn-outline-primary"
            data-file-trigger="aadhaarDocInput"
          >
            <%= agentAadhaarDoc ? "Edit Document" : "Upload Document" %>
          </button>
          <% if (agentAadhaarDoc) { %>
            <a class="btn btn-secondary" href="<%= agentAadhaarDoc %>" target="_blank" rel="noopener noreferrer">View Current</a>
          <% } %>
          <span class="agent-upload-card__status" data-file-name="aadhaarDoc">
            <%= agentAadhaarDoc ? "Current document uploaded." : "No document uploaded yet." %>
          </span>
        </div>

        <input
          id="aadhaarDocInput"
          type="file"
          name="aadhaarDoc"
          accept="image/jpeg,image/png,image/webp,.pdf,application/pdf"
          hidden
          data-file-input="aadhaarDoc"
        />
      </section>
    </div>

    <div class="agent-profile-form__grid">
      <label>
        Full Name
        <input name="fullName" type="text" value="<%= (agent && agent.fullName) || '' %>" required />
      </label>

      <label>
        Email
        <input name="email" type="email" value="<%= (agent && agent.email) || (currentUser && currentUser.email) || '' %>" required />
      </label>

      <label>
        Phone Number
        <input
          name="phoneNumber"
          type="tel"
          value="<%= (agent && agent.phoneNumber) || '' %>"
          maxlength="10"
          pattern="[6-9][0-9]{9}"
          inputmode="numeric"
          required
        />
      </label>

      <label>
        Working Region
        <input name="workingRegion" type="text" value="<%= (agent && (agent.workingRegion || agent.region)) || '' %>" required />
      </label>

      <label class="agent-profile-form__span-2">
        Company / Brand Name
        <input name="companyName" type="text" value="<%= (agent && agent.companyName) || '' %>" placeholder="Shown to nurses and public leads where applicable" />
      </label>
    </div>

    <div class="agent-profile-form__actions">
      <button type="button" class="btn btn-secondary" id="agentProfileCancelBtn">Reset</button>
      <button type="submit" class="btn btn-primary" id="agentProfileSaveBtn">
        <span class="btn-text">Save Changes</span>
        <span class="btn-spinner" aria-hidden="true"></span>
      </button>
    </div>
  </form>

  <div class="profile-section quick-actions" data-reveal>
    <h2>Quick Actions</h2>
    <div class="quick-actions__grid">
      <a href="/agent/nurses/new" class="btn btn-primary">+ Add Nurse</a>
      <a href="/agent/jobs/new" class="btn btn-success">+ Add Job</a>
      <a href="/agent/dashboard?tab=staff" class="btn btn-outline-primary">View Staff</a>
      <a href="/agent/dashboard?tab=jobs" class="btn btn-outline-primary">View Jobs</a>
    </div>
  </div>

  <div class="profile-section" data-reveal>
    <h2>Nurse Network</h2>

    <div class="nurse-grid">
      <% if (featuredNurses && featuredNurses.length) { %>
        <% featuredNurses.forEach((nurse) => { %>
          <%- include("../partials/nurse-directory-card", {
            nurse,
            href: `/agent/nurses/${nurse.id}`,
            hrefLabel: "Manage Nurse",
            mode: "compact",
            showRequestButton: false,
            showUtilityButtons: false,
            showDeleteButton: false
          }) %>
        <% }) %>
      <% } else { %>
        <div class="agent-network-card" data-reveal>
          <img src="/images/nurse.svg" alt="Nurse" />
          <h4>No featured nurses yet</h4>
          <p>Approved nurses from this account will appear here automatically.</p>
          <a class="btn btn-outline-primary" href="/agent/nurses/new">Add Nurse</a>
        </div>
      <% } %>
    </div>
  </div>

  <div class="profile-section" data-reveal>
    <h2>Contact Summary</h2>
    <div class="contact-card">
      <p><strong>Phone:</strong> <%= (agent && agent.phoneNumber) || 'Not shared' %></p>
      <p><strong>Email:</strong> <%= (agent && agent.email) || (currentUser && currentUser.email) || 'Not shared' %></p>
      <p><strong>Region:</strong> <%= (agent && (agent.workingRegion || agent.region)) || 'Not shared' %></p>
      <p><strong>Company:</strong> <%= (agent && agent.companyName) || 'Prisha Home Care Partner' %></p>
    </div>
  </div>
</section>

<script src="/js/agent-profile.js"></script>
<%- include("../partials/footer") %>
