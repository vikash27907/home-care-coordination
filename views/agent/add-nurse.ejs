<%- include("../partials/head", { title, extraStylesheets: ["/css/agent-dashboard-tabs.css", "/css/agent-add-nurse.css"] }) %>

<section class="agent-add-nurse-page container">
  <div class="agent-add-nurse-page__header" data-reveal>
    <div>
      <p class="agent-hub__eyebrow">Agent Panel</p>
      <h1>Add Nurse</h1>
      <p class="agent-hub__intro">
        Create a nurse in under a minute. Bio, skills, and the rest of the profile can be completed later after login.
      </p>
    </div>
    <a href="/agent/dashboard?tab=staff" class="btn btn-secondary agent-add-nurse-page__back">Back to Staff</a>
  </div>

  <form
    method="POST"
    action="/agent/nurses/new"
    enctype="multipart/form-data"
    class="agent-add-nurse-form card shadow-sm"
    id="agentAddNurseForm"
    data-reveal
  >
    <div class="agent-add-nurse-form__top">
      <div>
        <h2>Quick Nurse Entry</h2>
        <p>Only the essentials for now. A temporary password will be generated automatically.</p>
      </div>
      <span class="agent-add-nurse-form__badge">Mobile Fast</span>
    </div>

    <div class="agent-add-nurse-form__fields">
      <label class="agent-add-nurse-form__field">
        <span>First Name</span>
        <input
          name="fullName"
          type="text"
          autocomplete="given-name"
          placeholder="Enter first name"
          required
        />
      </label>

      <label class="agent-add-nurse-form__field">
        <span>Phone Number</span>
        <input
          name="phoneNumber"
          type="tel"
          maxlength="10"
          inputmode="numeric"
          pattern="[6-9][0-9]{9}"
          placeholder="10-digit mobile number"
          autocomplete="tel"
          required
        />
      </label>

      <label class="agent-add-nurse-form__field">
        <span>Location</span>
        <input
          name="city"
          type="text"
          autocomplete="address-level2"
          placeholder="City or area"
          required
        />
      </label>

      <label class="agent-add-nurse-form__field">
        <span>Experience</span>
        <div class="agent-add-nurse-form__inline-input">
          <input
            name="experienceYears"
            type="number"
            min="0"
            max="60"
            inputmode="numeric"
            placeholder="Years"
            required
          />
          <small>Years</small>
        </div>
      </label>

      <label class="agent-add-nurse-form__field">
        <span>Availability</span>
        <select name="availability" required>
          <option value="">Select availability</option>
          <option value="Available for Work">Available for Work</option>
          <option value="Currently Working">Currently Working</option>
          <option value="Open to Opportunities">Open to Opportunities</option>
          <option value="Not Available">Not Available</option>
        </select>
      </label>

      <div class="agent-add-nurse-form__field">
        <span>Profile Photo</span>
        <label class="agent-add-nurse-upload" for="profileImageInput">
          <input
            id="profileImageInput"
            name="profileImage"
            type="file"
            accept="image/*"
          />
          <span class="agent-add-nurse-upload__label">Upload image</span>
          <span class="agent-add-nurse-upload__meta" id="profileImageFileName">Camera or gallery supported</span>
        </label>
        <div class="agent-add-nurse-upload__preview" id="profileImagePreviewShell" hidden>
          <img id="profileImagePreview" alt="Selected nurse profile preview" />
        </div>
      </div>
    </div>

    <div class="agent-add-nurse-form__notes">
      <p>Nurse login access is created automatically with a temporary password.</p>
      <p>Bio, skills, and other profile details can be updated later after account creation.</p>
    </div>

    <div class="agent-add-nurse-form__sticky-bar">
      <a href="/agent/dashboard?tab=staff" class="btn btn-secondary">Cancel</a>
      <button type="submit" class="btn btn-primary" id="agentAddNurseSubmitBtn">
        <span class="btn-text">Add Nurse</span>
        <span class="btn-spinner" aria-hidden="true"></span>
      </button>
    </div>
  </form>
</section>

<script>
  (() => {
    const form = document.getElementById("agentAddNurseForm");
    const submitButton = document.getElementById("agentAddNurseSubmitBtn");
    const fileInput = document.getElementById("profileImageInput");
    const fileNameLabel = document.getElementById("profileImageFileName");
    const previewShell = document.getElementById("profileImagePreviewShell");
    const previewImage = document.getElementById("profileImagePreview");
    let activePreviewUrl = "";

    if (fileInput && fileNameLabel && previewShell && previewImage) {
      fileInput.addEventListener("change", () => {
        if (activePreviewUrl) {
          URL.revokeObjectURL(activePreviewUrl);
          activePreviewUrl = "";
        }

        const [file] = Array.from(fileInput.files || []);
        if (!file) {
          fileNameLabel.textContent = "Camera or gallery supported";
          previewShell.hidden = true;
          previewImage.removeAttribute("src");
          return;
        }

        fileNameLabel.textContent = file.name;
        if (!String(file.type || "").startsWith("image/")) {
          previewShell.hidden = true;
          previewImage.removeAttribute("src");
          return;
        }

        activePreviewUrl = URL.createObjectURL(file);
        previewImage.src = activePreviewUrl;
        previewShell.hidden = false;
      });
    }

    if (form && submitButton) {
      form.addEventListener("submit", () => {
        submitButton.disabled = true;
        submitButton.classList.add("is-loading");
      });
    }
  })();
</script>

<%- include("../partials/footer") %>
