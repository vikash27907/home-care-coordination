<%- include("../partials/head", {
  title,
  metaTitle: "Prisha Home Care | Professional Home Nursing Services",
  metaDescription:
    "Prisha Home Care provides trusted home nursing, patient support, and coordinated care services delivered safely and professionally."
}) %>

<section class="hero-shell">
  <div class="hero-heartbeat" aria-hidden="true">
    <svg viewBox="0 0 320 140" role="presentation" focusable="false">
      <path d="M10 78h58l18-24 24 52 38-82 24 54h138" />
    </svg>
  </div>
  <div class="hero-grid reveal" data-reveal>
    <div class="hero-media">
      <div class="hero-image">
        <img
          src="/images/hero.jpg?v=<%= assetVersion %>"
          alt="Prisha Home Care professional supporting a patient at home"
        />
      </div>
    </div>
    <div class="hero-content">
      <p class="hero-eyebrow">
        <span class="hero-eyebrow-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" role="presentation" focusable="false">
            <path d="M12 20.2s-6.7-4.3-8.6-8C2 9.6 3 6.6 5.7 5.4c2-.9 4.1-.2 5.3 1.4 1.2-1.6 3.4-2.3 5.3-1.4 2.7 1.2 3.7 4.2 2.3 6.8-1.9 3.7-8.6 8-8.6 8Z" />
            <path d="M7.2 12h2.1l1.1-2.2 1.8 4.5 1.2-2.3h3" />
          </svg>
        </span>
        PRISHA HOME CARE
      </p>
      <h1>Care That Comes Home</h1>
      <p class="hero-copy">Trusted nurses and attendants for safe and reliable home care.</p>
      <div class="hero-actions">
        <a href="/nurses" class="btn primary hero-primary-btn">Find a Nurse</a>
        <a href="/request-care" class="btn light hero-secondary-btn">Need help? Request Care</a>
      </div>
    </div>
  </div>
</section>

<section class="content-section staff-cta-section">
  <div class="section-heading reveal" data-reveal>
    <p class="section-kicker">Career &amp; Partnership</p>
    <h2>Grow with our care network</h2>
    <p class="section-lead">Join Prisha Home Care as a trusted staff member or referral partner and help more families access dependable support.</p>
  </div>
  <div class="staff-cta-grid reveal" data-reveal>
    <article class="staff-cta-card">
      <span class="staff-cta-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" role="presentation" focusable="false">
          <path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" />
          <circle cx="9.5" cy="7" r="4" />
          <path d="M19 8v6" />
          <path d="M16 11h6" />
        </svg>
      </span>
      <h3>Register as Staff</h3>
      <p>Apply as a nurse or care professional and get discovered by families who need reliable home support.</p>
      <a href="/nurse-signup" class="btn primary">Register as Staff</a>
    </article>
    <article class="staff-cta-card">
      <span class="staff-cta-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" role="presentation" focusable="false">
          <path d="M3 7.5A2.5 2.5 0 0 1 5.5 5h13A2.5 2.5 0 0 1 21 7.5v9A2.5 2.5 0 0 1 18.5 19h-13A2.5 2.5 0 0 1 3 16.5z" />
          <path d="M8 5V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v1" />
          <path d="M3 11h18" />
        </svg>
      </span>
      <h3>Join as Agent</h3>
      <p>Partner with us to refer and coordinate care opportunities while building a trusted local network.</p>
      <a href="/agent-registration" class="btn primary">Join as Agent</a>
    </article>
  </div>
</section>

<section class="content-section customer-action-section">
  <div class="customer-action-panel reveal" data-reveal>
    <div class="section-heading">
      <p class="section-kicker">For families and patients</p>
      <h2>Find the right care quickly</h2>
      <p class="section-lead">Choose a verified professional or submit a request and our team will help you.</p>
    </div>
    <div class="customer-actions">
      <a href="/nurses" class="btn primary">Find a Nurse</a>
      <a href="/request-care" class="btn light">Request Care</a>
    </div>
  </div>
</section>

<section class="content-section trust-section">
  <div class="trust-strip reveal" data-reveal>
    <article class="trust-pill">
      <span class="trust-icon" aria-hidden="true">&#10003;</span>
      <span class="trust-label">Verified Staff</span>
    </article>
    <article class="trust-pill">
      <span class="trust-icon" aria-hidden="true">&#10010;</span>
      <span class="trust-label">Professional Care</span>
    </article>
    <article class="trust-pill">
      <span class="trust-icon" aria-hidden="true">&#9733;</span>
      <span class="trust-label">Trusted by Families</span>
    </article>
  </div>
</section>

<%- include("../partials/footer") %>
