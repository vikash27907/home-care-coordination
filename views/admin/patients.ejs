<%- include("../partials/head", { title }) %>

<section class="dashboard-header">
  <h1>Patient Management</h1>
  <p>Review request readiness, application depth, and assignment progress.</p>
</section>

<div class="patient-grid">
  <% if (!requests || requests.length === 0) { %>
    <div class="empty-state">
      <h3>No care requests found.</h3>
      <p>Create a new request to get started.</p>
    </div>
  <% } %>

  <% requests.forEach((request) => { %>
    <% const statusClass = String(request.status || "").toLowerCase().replace(/[^a-z0-9_-]/g, ""); %>
    <div class="patient-card">
      <div class="card-header">
        <span class="patient-id">REQ #<%= request.id %></span>
        <span class="status-badge <%= statusClass %>">
          <%= request.status %>
        </span>
      </div>

      <h3 class="patient-name"><%= request.full_name %></h3>

      <div class="patient-meta">
        <p><strong>Location:</strong> <%= request.location %></p>
        <p><strong>Shift:</strong> <%= request.shift_timing %></p>
        <p><strong>Pay:</strong> <%= request.price_per_day ? `₹${request.price_per_day}/day` : "Open" %></p>
        <p><strong>Applications:</strong> <%= request.application_count %></p>
      </div>

      <div class="card-actions">
        <a href="/admin/care-request/<%= request.id %>" class="btn-outline">
          View Details
        </a>

        <% if (request.status === "open") { %>
          <a href="/admin/care-request/<%= request.id %>/applicants" class="btn-primary">
            View Applicants
          </a>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>

<%- include("../partials/footer") %>
