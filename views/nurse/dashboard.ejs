<%- include("../partials/head", { title }) %>

<section class="dashboard-header">
  <h1>Nurse Dashboard</h1>
  <p>Personal application and assignment intelligence.</p>
</section>

<% if (showOwnershipBanner) { %>
  <section class="ownership-banner" aria-live="polite">
    <div>
      <strong>This account was created by an agent.</strong>
      <p>Verify your email to take full control of your profile.</p>
    </div>
    <a href="/verify-email" class="btn primary small">Verify Email</a>
  </section>
<% } %>

<div class="dashboard-grid">
  <a href="/nurse/care-requests#pending" class="dash-card blue">
    <h3><%= stats.pending_apps %></h3>
    <p>Pending Applications</p>
  </a>

  <a href="/nurse/care-requests#assigned" class="dash-card green">
    <h3><%= stats.assigned_jobs %></h3>
    <p>Assigned Jobs</p>
  </a>

  <a href="/nurse/care-requests#completed" class="dash-card purple">
    <h3><%= stats.completed_jobs %></h3>
    <p>Completed Jobs</p>
  </a>

  <a href="/request-care" class="dash-card teal">
    <h3><%= stats.marketplace_open %></h3>
    <p>Find Jobs</p>
  </a>
</div>

<style>
.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 24px;
  padding: 30px 0;
}

.ownership-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 18px 20px;
  margin-top: 18px;
  border: 1px solid #b7d9f7;
  border-radius: 16px;
  background: linear-gradient(135deg, #eef7ff, #f7fbff);
  color: #12344d;
}

.ownership-banner p {
  margin: 6px 0 0;
}

.dash-card {
  padding: 25px;
  border-radius: 16px;
  text-decoration: none;
  color: white;
  cursor: pointer;
  display: block;
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
  transition: 0.3s ease;
}

.dash-card:hover {
  transform: translateY(-6px);
}

.dash-card h3 {
  font-size: 28px;
  margin-bottom: 8px;
}

.blue { background: linear-gradient(90deg, #0052cc, #0077ff); }
.green { background: linear-gradient(90deg, #198754, #20c997); }
.purple { background: linear-gradient(90deg, #6f42c1, #9b5de5); }
.teal { background: linear-gradient(90deg, #0f766e, #14b8a6); }

@media (max-width: 700px) {
  .ownership-banner {
    flex-direction: column;
    align-items: stretch;
  }

  .ownership-banner .btn {
    width: 100%;
  }
}
</style>

<%- include("../partials/footer") %>
