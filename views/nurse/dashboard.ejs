<%- include("../partials/head", { title }) %>

<section class="dashboard-header">
  <h1>Nurse Dashboard</h1>
  <p>Personal application and assignment intelligence.</p>
</section>

<% if (showOwnershipBanner) { %>
  <section class="ownership-banner" aria-live="polite">
    <div>
      <strong>This account was created by an agent.</strong>
      <p><%= currentUser && currentUser.email ? "Verify your email to take full control of your profile." : "Add an email address to enable email login and secure your account." %></p>
    </div>
    <% if (currentUser && currentUser.email) { %>
      <a href="/verify-email" class="btn primary small">Verify Email</a>
    <% } %>
  </section>
<% } %>

<% if (currentUser && !currentUser.email_verified) { %>
  <section class="ownership-banner ownership-banner--warning" aria-live="polite">
    <div>
      <strong>Secure Your Account</strong>
      <p>Add email to enable email login.</p>
      <form action="/nurse/request-email-otp" method="POST" class="ownership-form">
        <input
          type="email"
          name="new_email"
          value="<%= pendingEmailVerification || currentUser.email || '' %>"
          required
          placeholder="Enter email"
        >
        <button type="submit" class="btn primary small">Send OTP</button>
      </form>

      <% if (pendingEmailVerification) { %>
        <form action="/nurse/verify-email-otp" method="POST" class="ownership-form ownership-form--otp">
          <input
            type="text"
            name="otp"
            inputmode="numeric"
            pattern="[0-9]{6}"
            maxlength="6"
            required
            placeholder="Enter 6-digit OTP"
          >
          <button type="submit" class="btn small">Verify OTP</button>
        </form>
      <% } %>
    </div>
  </section>
<% } %>

<% if (profileCard) { %>
  <section class="dashboard-preview">
    <div class="section-head">
      <div>
        <h2>Your Public Card</h2>
        <p class="text-muted">This is the same card patients and agents see across the platform.</p>
      </div>
    </div>
    <div class="nurse-cards-grid nurse-cards-grid--single">
      <%- include("../partials/nurse-directory-card", {
        nurse: profileCard,
        href: profileCard.publicUrl,
        mode: "full",
        showRequestButton: false,
        showUtilityButtons: true,
        shareCardEnabled: true,
        shareCardProfileUrl: profileCard.publicUrl
      }) %>
    </div>
  </section>
<% } %>

<div class="dashboard-grid">
  <a href="/nurse/care-requests#pending" class="dash-card blue">
    <h3><%= stats.pending_apps %></h3>
    <p>Pending Applications</p>
  </a>

  <a href="/nurse/care-requests#assigned" class="dash-card green">
    <h3><%= stats.assigned_jobs %></h3>
    <p>Assigned Jobs</p>
  </a>

  <a href="/nurse/care-requests#completed" class="dash-card purple">
    <h3><%= stats.completed_jobs %></h3>
    <p>Completed Jobs</p>
  </a>

  <a href="/request-care" class="dash-card teal">
    <h3><%= stats.marketplace_open %></h3>
    <p>Find Jobs</p>
  </a>
</div>

<style>
.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 24px;
  padding: 30px 0;
}

.ownership-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 18px 20px;
  margin-top: 18px;
  border: 1px solid #b7d9f7;
  border-radius: 16px;
  background: linear-gradient(135deg, #eef7ff, #f7fbff);
  color: #12344d;
}

.ownership-banner--warning {
  margin-top: 18px;
  border-color: #f5d48b;
  background: linear-gradient(135deg, #fff8e8, #fffdf5);
  color: #5b410c;
}

.ownership-banner p {
  margin: 6px 0 0;
}

.ownership-form {
  display: flex;
  gap: 10px;
  margin-top: 14px;
  flex-wrap: wrap;
}

.ownership-form input {
  flex: 1 1 240px;
  min-height: 42px;
  padding: 0.7rem 0.9rem;
  border: 1px solid rgba(18, 52, 77, 0.14);
  border-radius: 12px;
  background: #fff;
}

.ownership-form--otp input {
  max-width: 220px;
}

.dashboard-preview {
  margin-top: 28px;
}

.nurse-cards-grid--single {
  grid-template-columns: minmax(0, 420px);
}

.dash-card {
  padding: 25px;
  border-radius: 16px;
  text-decoration: none;
  color: white;
  cursor: pointer;
  display: block;
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
  transition: 0.3s ease;
}

.dash-card:hover {
  transform: translateY(-6px);
}

.dash-card h3 {
  font-size: 28px;
  margin-bottom: 8px;
}

.blue { background: linear-gradient(90deg, #0052cc, #0077ff); }
.green { background: linear-gradient(90deg, #198754, #20c997); }
.purple { background: linear-gradient(90deg, #6f42c1, #9b5de5); }
.teal { background: linear-gradient(90deg, #0f766e, #14b8a6); }

@media (max-width: 700px) {
  .ownership-banner {
    flex-direction: column;
    align-items: stretch;
  }

  .ownership-banner .btn {
    width: 100%;
  }

  .ownership-form {
    flex-direction: column;
  }
}
</style>

<%- include("../partials/footer") %>
