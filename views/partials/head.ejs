<%
  const assetVersion = typeof res !== "undefined" && res.locals && typeof res.locals.assetVersion !== "undefined"
    ? res.locals.assetVersion
    : (process.env.NODE_ENV === "production" ? "1.0.0" : Date.now());
  const styles = Array.isArray(typeof extraStylesheets !== "undefined" ? extraStylesheets : null)
    ? extraStylesheets
    : [];
%>
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <title>
      <%= (typeof metaTitle !== 'undefined' && metaTitle) ? metaTitle : (title ? `${title} | Prisha Home Care` : "Prisha Home Care | Professional Home Nursing Services") %>
    </title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <meta
      name="description"
      content="<%= (typeof metaDescription !== 'undefined' && metaDescription) ? metaDescription : 'Prisha Home Care provides trusted home nursing and coordinated care services for patients and families.' %>"
    />
    <meta name="theme-color" content="#1E88E5" />
    <link rel="manifest" href="/manifest.webmanifest?v=<%= assetVersion %>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800&family=Open+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/base.css?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="/css/utilities.css?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="/styles.css?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="/css/layout.css?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="/css/components.css?v=<%= assetVersion %>" />
    <% styles.forEach((href) => { %>
    <link rel="stylesheet" href="<%= href %>?v=<%= assetVersion %>" />
    <% }) %>
  </head>
  <body data-asset-version="<%= assetVersion %>" data-env="<%= process.env.NODE_ENV === 'production' ? 'production' : 'development' %>">
    <header class="site-header">
      <div class="wrap nav-wrap">
        <nav class="navbar">
          <% const isHomeActive = homeLink === "/" ? currentPath === "/" : (currentPath === homeLink || currentPath.startsWith(`${homeLink}/`)); %>
          <div class="nav-left">
            <a class="brand" href="<%= homeLink %>">
              <img src="/images/prisha-logo.png" alt="Prisha Home Care" class="brand-logo" />
              <span>Prisha Home Care</span>
            </a>
          </div>
          <div class="nav-links" id="navLinks">
            <a href="<%= homeLink %>" class="<%= isHomeActive ? 'active' : '' %>">Home</a>
            <a href="/nurses" class="<%= currentPath.startsWith('/nurses') ? 'active' : '' %>">Find Nurses</a>
            <a href="/request-care" class="<%= currentPath === '/request-care' ? 'active' : '' %>">Request Care</a>
            <% if (!(session && session.user)) { %>
            <a href="/login" class="nav-mobile-login <%= currentPath === '/login' ? 'active' : '' %>">Login</a>
            <% } %>
          </div>
          <div class="nav-right">
            <% if (session && session.user) { %>
            <% const profileHref = session.user.role === "user" ? "/" : `/${session.user.role}/profile`; %>
            <% const dashboardHref = homeLink || "/"; %>
            <div class="notification-center" id="notificationCenter">
              <button
                type="button"
                class="notification-bell"
                id="notificationBell"
                aria-haspopup="true"
                aria-expanded="false"
                aria-controls="notificationDropdown"
                title="Notifications"
              >
                <span aria-hidden="true">&#128276;</span>
                <span id="notification-count" class="notif-badge">0</span>
              </button>
              <div class="notification-dropdown" id="notificationDropdown" role="menu" aria-label="Notifications">
                <div class="notification-dropdown-header">
                  <strong>Notifications</strong>
                  <a href="/notifications-page">View all</a>
                </div>
                <div id="notification-list" class="notification-list">
                  <p class="notification-empty">Loading...</p>
                </div>
              </div>
            </div>
            <div class="profile-menu-shell">
              <a
                href="<%= profileHref %>"
                class="avatar-btn"
                aria-label="Open profile"
              >
                <img
                  src="<%= session.user.profileImageUrl || '/images/default-avatar.png' %>"
                  alt="Account"
                  class="nav-avatar"
                />
              </a>
              <button
                type="button"
                id="menu-toggle"
                class="menu-btn"
                aria-haspopup="menu"
                aria-expanded="false"
                aria-controls="profile-dropdown"
                title="Account menu"
              >
                &#9776;
              </button>
              <div class="dropdown-menu" id="profile-dropdown" role="menu" aria-label="Account menu">
                <a href="<%= profileHref %>" role="menuitem">
                  My Profile
                </a>
                <a href="<%= dashboardHref %>" role="menuitem">
                  Dashboard
                </a>
                <form method="POST" action="/logout">
                  <button type="submit" role="menuitem">Logout</button>
                </form>
              </div>
            </div>
            <% } else { %>
            <a href="/login" class="btn-login desktop-login <%= currentPath === '/login' ? 'active' : '' %>">Login</a>
            <button
              type="button"
              class="hamburger"
              id="navToggle"
              aria-label="Toggle navigation menu"
              aria-controls="navLinks"
              aria-expanded="false"
            >
              &#9776;
            </button>
            <% } %>
          </div>
        </nav>
      </div>
    </header>
    <main class="wrap main-wrap">
      <% if (flash) { %>
      <section class="flash <%= flash.type %>"><%= flash.message %></section>
      <% } %>
