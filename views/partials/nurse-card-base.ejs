<%
const nurseName = String((nurse && (nurse.fullName || nurse.full_name)) || "Nurse").trim();
const uniqueId = String((nurse && (nurse.uniqueId || nurse.unique_id)) || "").trim() || "PHCN000";
const imageSrc = String(
  (nurse && (
    nurse.profileImageUrl
    || nurse.profile_image_url
    || nurse.profileImagePath
    || nurse.profile_image_path
  )) || "/images/default-avatar.png"
).trim();
const nurseId = Number.parseInt((nurse && nurse.id) || 0, 10);
const profileSlug = String((nurse && (nurse.profileSlug || nurse.profile_slug)) || "").trim();
const statusLabel = String((nurse && nurse.status) || "").trim();
const isVerified = nurse && (nurse.isVerified === true || String(statusLabel).toLowerCase() === "approved");
const isActive = nurse && (nurse.isAvailable !== false);
const ratingAverage = Number.isFinite(Number(nurse && nurse.ratingAverage)) ? Number(nurse.ratingAverage) : 0;
const reviewCount = Number.parseInt((nurse && nurse.reviewCount) || 0, 10) || 0;
const qualification = String(
  (nurse && (
    nurse.qualificationPrimary
    || nurse.qualificationsText
  )) || ""
).trim() || "GNM (Nursing)";
const gender = String((nurse && nurse.gender) || "Not specified").trim();
const religion = String((nurse && nurse.religion) || "").trim();
const experienceYears = Number.parseInt((nurse && (nurse.experienceYears || nurse.experience_years)) || 0, 10) || 0;
const experienceLabel = String(
  (nurse && (
    nurse.experienceText
    || nurse.experienceLabel
  )) || ""
).trim() || `${experienceYears} Years`;
const city = String((nurse && nurse.city) || "").trim() || "Not shared";
const dutyType = String((nurse && (nurse.dutyType || nurse.duty_type)) || "").trim() || "12 hrs / 24 hrs";
const heightValue = String((nurse && (nurse.height || nurse.heightText || nurse.height_text)) || "").trim();
const weightRaw = nurse && (nurse.weightKg || nurse.weight_kg || nurse.weight);
const weightValue = Number.isFinite(Number(weightRaw)) ? `${Number(weightRaw)} kg` : "";
const availabilityValue = String(
  (nurse && (
    nurse.availabilityLabel
    || nurse.availability_label
    || nurse.currentStatus
    || nurse.current_status
  )) || ""
).trim() || (isActive ? "Available" : "Unavailable");
const languages = Array.isArray(nurse && nurse.languages) ? nurse.languages.filter(Boolean) : [];
const skills = Array.isArray(nurse && nurse.skills) ? nurse.skills.filter(Boolean) : [];
const contactInfo = contactContext && typeof contactContext === "object" ? contactContext : {};
const rawPhoneNumber = String(
  (contactInfo.phone || contactInfo.displayPhone || contactPhone)
  || (nurse && (nurse.phoneNumber || nurse.phone_number))
  || ""
).trim();
const normalizedPhoneDigits = rawPhoneNumber.replace(/\D/g, "").slice(-10);
const formattedPhoneNumber = normalizedPhoneDigits ? `+91 ${normalizedPhoneDigits.slice(0, 5)} ${normalizedPhoneDigits.slice(5)}` : rawPhoneNumber;
const contactLink = String(
  contactInfo.actionHref
  || contactInfo.whatsappHref
  || contactInfo.telHref
  || contactHref
  || (normalizedPhoneDigits ? `tel:+91${normalizedPhoneDigits}` : "")
).trim();
const openContactInNewTab = contactInfo.openInNewTab === true || /^https?:\/\//i.test(contactLink);
const contactButtonLabel = String(contactInfo.buttonLabel || contactButtonText || "Contact").trim() || "Contact";
const contactLabel = String(contactInfo.contactLabel || "").trim();
const documents = Array.isArray(nurse && nurse.documents)
  ? nurse.documents.filter((item) => item && item.available && item.href)
  : [
    {
      key: "aadhaar",
      label: "Aadhaar Card",
      href: String((nurse && (nurse.aadhaarCardUrl || nurse.aadharImageUrl || nurse.aadhar_image_url)) || "").trim(),
      available: Boolean(nurse && (nurse.aadhaarCardUrl || nurse.aadharImageUrl || nurse.aadhar_image_url))
    },
    {
      key: "certificate",
      label: "Certificate",
      href: String((nurse && (nurse.certificateUrl || nurse.certificate_url)) || "").trim(),
      available: Boolean(nurse && (nurse.certificateUrl || nurse.certificate_url))
    },
    {
      key: "medical-fit",
      label: "Medical Fit",
      href: String((nurse && (nurse.medicalFitUrl || nurse.medical_fit_url)) || "").trim(),
      available: Boolean(nurse && (nurse.medicalFitUrl || nurse.medical_fit_url))
    }
  ].filter((item) => item && item.available && item.href);
const showQr = typeof showQrCode === "undefined" ? false : showQrCode === true;
const showContactSection = typeof showContact === "undefined" ? true : showContact === true;
const filledStars = ratingAverage > 0 ? Math.max(1, Math.min(5, Math.round(ratingAverage))) : 0;
function isPreviewableImage(url) {
  return /\.(png|jpe?g|webp|gif|bmp|svg)(\?.*)?$/i.test(String(url || "").trim());
}

function icon(name, className) {
  const cls = className ? ` class="${className}"` : "";
  const icons = {
    verified: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.5 2.2 3.3-.3 1.1 3.1 2.7 1.9-1 3.2 1 3.2-2.7 1.9-1.1 3.1-3.3-.3L12 22l-2.5-2.2-3.3.3-1.1-3.1-2.7-1.9 1-3.2-1-3.2 2.7-1.9 1.1-3.1 3.3.3L12 2z" fill="currentColor" opacity=".18"/><path d="M8.5 12.2l2.1 2.1 5-5.2" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    star: `<svg${cls} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3.6l2.5 5.1 5.7.8-4.1 4 1 5.7-5.1-2.7-5.1 2.7 1-5.7-4.1-4 5.7-.8L12 3.6z"/></svg>`,
    id: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="3" stroke="currentColor" stroke-width="1.8"/><circle cx="8" cy="12" r="2.1" fill="currentColor"/><path d="M12.5 10h5M12.5 13h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
    active: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" fill="currentColor" opacity=".16"/><path d="M7.8 12.3l2.8 2.8 5.6-6.2" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    experience: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l2 4.5L19 8l-3.6 3.3.9 4.8L12 13.9l-4.3 2.2.9-4.8L5 8l5-.5L12 3z" fill="currentColor" opacity=".18"/><path d="M12 5.1l1.3 2.7 3 .4-2.2 2 .5 3-2.6-1.3-2.6 1.3.5-3-2.2-2 3-.4L12 5.1z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
    qualification: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 9.5L12 5l9 4.5L12 14 3 9.5z" fill="currentColor" opacity=".18"/><path d="M6.5 11.5V15c0 1.7 2.4 3 5.5 3s5.5-1.3 5.5-3v-3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M3 9.5L12 5l9 4.5L12 14 3 9.5z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>`,
    gender: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="3.5" fill="currentColor" opacity=".18"/><path d="M6.5 20a5.5 5.5 0 0111 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="8" r="3.5" stroke="currentColor" stroke-width="1.8"/></svg>`,
    briefcase: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="7" width="18" height="12" rx="3" stroke="currentColor" stroke-width="1.8"/><path d="M9 7V5.8A1.8 1.8 0 0110.8 4h2.4A1.8 1.8 0 0115 5.8V7" stroke="currentColor" stroke-width="1.8"/><path d="M3 12h18" stroke="currentColor" stroke-width="1.8"/></svg>`,
    location: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s6-5.8 6-11a6 6 0 10-12 0c0 5.2 6 11 6 11z" fill="currentColor" opacity=".16"/><circle cx="12" cy="10" r="2.2" stroke="currentColor" stroke-width="1.8"/><path d="M12 21s6-5.8 6-11a6 6 0 10-12 0c0 5.2 6 11 6 11z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>`,
    clock: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/><path d="M12 7.5v5l3.2 1.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    height: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M8 4h8M8 20h8M12 4v16M9.5 7L12 4l2.5 3M9.5 17L12 20l2.5-3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    weight: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 10.5A5.5 5.5 0 0110.5 5h3A5.5 5.5 0 0119 10.5V18a2 2 0 01-2 2H7a2 2 0 01-2-2v-7.5z" stroke="currentColor" stroke-width="1.8"/><path d="M9.5 10a2.5 2.5 0 015 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M12 10l1 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
    availability: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="6.5" fill="currentColor"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" opacity=".18"/></svg>`,
    language: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/><path d="M3.5 12h17M12 3a14.5 14.5 0 014 9 14.5 14.5 0 01-4 9 14.5 14.5 0 01-4-9 14.5 14.5 0 014-9z" stroke="currentColor" stroke-width="1.4"/></svg>`,
    phone: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7.3 4.7l2.2 3.8-1.4 1.8a14.5 14.5 0 005.4 5.4l1.8-1.4 3.8 2.2-1.2 3.7a2 2 0 01-2.2 1.3A18.5 18.5 0 013.7 8.1a2 2 0 011.3-2.2l2.3-1.2z" fill="currentColor" opacity=".18"/><path d="M7.3 4.7l2.2 3.8-1.4 1.8a14.5 14.5 0 005.4 5.4l1.8-1.4 3.8 2.2-1.2 3.7a2 2 0 01-2.2 1.3A18.5 18.5 0 013.7 8.1a2 2 0 011.3-2.2l2.3-1.2z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>`,
    whatsapp: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3.6a8.4 8.4 0 00-7.3 12.5L4 20l4-1a8.4 8.4 0 104-15.4z" fill="currentColor" opacity=".18"/><path d="M12 3.6a8.4 8.4 0 00-7.3 12.5L4 20l4-1a8.4 8.4 0 104-15.4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M9.4 8.7c-.3.1-.8.8-.9 1.2-.1.4.1 1 .3 1.5.3.7.9 1.6 1.8 2.5.9.9 1.8 1.5 2.5 1.8.5.2 1.1.4 1.5.3.4-.1 1.1-.6 1.2-.9.1-.3.1-.6 0-.7l-1.4-.7c-.1-.1-.3 0-.4.1l-.5.6c-.1.1-.2.1-.4.1-.3-.1-1-.4-1.9-1.2-.8-.8-1.1-1.5-1.2-1.9 0-.1 0-.3.1-.4l.6-.5c.1-.1.2-.2.1-.4l-.7-1.4c-.1-.1-.4-.1-.7 0z" fill="currentColor"/></svg>`,
    aadhaar: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="4" y="5" width="16" height="14" rx="2.5" stroke="currentColor" stroke-width="1.8"/><path d="M8 9h8M8 12h8M8 15h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="16.5" cy="15.2" r="2" fill="currentColor" opacity=".2"/></svg>`,
    certificate: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 4.5h8l3 3V19a2 2 0 01-2 2H7a2 2 0 01-2-2V6.5a2 2 0 012-2z" stroke="currentColor" stroke-width="1.8"/><path d="M15 4.5v3h3" stroke="currentColor" stroke-width="1.8"/><path d="M8.5 12h7M8.5 15h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    medical: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="5" y="5" width="14" height="14" rx="4" stroke="currentColor" stroke-width="1.8"/><path d="M12 8.2v7.6M8.2 12h7.6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
    user: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="3.4" stroke="currentColor" stroke-width="1.8"/><path d="M5.5 19a6.5 6.5 0 0113 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`
  };

  return icons[name] || icons.user;
}

function skillIconName(skill) {
  const key = String(skill || "").trim().toLowerCase();
  if (key.includes("injection")) return "medical";
  if (key.includes("first aid")) return "medical";
  if (key.includes("medicine")) return "certificate";
  if (key.includes("baby")) return "user";
  if (key.includes("elder")) return "user";
  return "verified";
}
%>

<article class="nurse-card-base nurse-card-base--health full">
  <div class="nurse-card-base__backdrop" aria-hidden="true"></div>
  <div class="nurse-card-base__watermark" aria-hidden="true"></div>

  <div class="nurse-card-base__brand-top">
    <div class="nurse-card-base__brand-logo">
      <img src="/images/prisha-logo.png" alt="Prisha Home Care" onerror="this.style.display='none';" />
      <div>
        <strong>Prisha <span>Home Care</span></strong>
        <p>Book Nurses &amp; Caregivers Online</p>
      </div>
    </div>
  </div>

  <div class="nurse-card-base__main">
    <header class="nurse-card-base__hero">
      <div class="nurse-card-base__avatar-panel">
        <div class="nurse-card-base__avatar-ring">
          <img
            src="<%= imageSrc %>"
            alt="<%= nurseName %> profile"
            class="nurse-card-base__avatar"
            onerror="this.onerror=null;this.src='/images/default-avatar.png';"
            data-preview-image="<%= imageSrc %>"
            data-preview-label="<%= nurseName %> profile photo"
            role="button"
            tabindex="0"
          />
          <span class="nurse-card-base__verify-dot" aria-label="<%= isVerified ? 'Verified nurse' : 'Verification pending' %>">
            <%- icon(isVerified ? "verified" : "user", "nurse-card-base__verify-icon") %>
          </span>
        </div>

        <div class="nurse-card-base__verified-pill">
          <%- icon("verified", "nurse-card-base__inline-icon") %>
          <span><%= isVerified ? "Verified" : "Pending Verification" %></span>
        </div>

        <% if (showQr && nurseId > 0) { %>
          <div class="nurse-card-base__qr-float">
            <img src="/api/nurse/<%= nurseId %>/qr" alt="QR code for <%= nurseName %> profile" loading="lazy" />
            <span>Scan to verify nurse profile</span>
          </div>
        <% } %>
      </div>

      <div class="nurse-card-base__hero-copy">
        <h2 class="nurse-card-base__name"><%= nurseName %></h2>

        <div class="nurse-card-base__rating">
          <div class="nurse-card-base__stars" aria-label="<%= ratingAverage > 0 ? `${ratingAverage.toFixed(1)} out of 5 stars` : 'No reviews yet' %>">
            <% for (let index = 0; index < 5; index += 1) { %>
              <span class="nurse-card-base__star <%= index < filledStars ? 'is-filled' : '' %>">
                <%- icon("star", "nurse-card-base__star-icon") %>
              </span>
            <% } %>
          </div>
          <div class="nurse-card-base__rating-text">
            <strong><%= ratingAverage > 0 ? ratingAverage.toFixed(1) : "New" %></strong>
            <span><%= reviewCount > 0 ? `(${reviewCount} Reviews)` : "(0 Reviews)" %></span>
          </div>
        </div>

        <div class="nurse-card-base__hero-badges">
          <div class="nurse-card-base__hero-pill nurse-card-base__hero-pill--id">
            <%- icon("id", "nurse-card-base__pill-icon") %>
            <span>ID: <strong><%= uniqueId %></strong></span>
          </div>
          <div class="nurse-card-base__hero-pill nurse-card-base__hero-pill--active">
            <%- icon("active", "nurse-card-base__pill-icon") %>
            <span><%= isActive ? "Active" : "Unavailable" %></span>
          </div>
        </div>

        <div class="nurse-card-base__experience-pill">
          <%- icon("experience", "nurse-card-base__pill-icon") %>
          <span><strong><%= experienceYears %> <%= experienceYears === 1 ? "Year" : "Years" %></strong> Experience</span>
        </div>
      </div>
    </header>

    <section class="nurse-card-base__details-grid">
      <div class="nurse-card-base__details-card">
        <div class="nurse-card-base__detail-row">
          <span class="nurse-card-base__detail-label"><%- icon("qualification", "nurse-card-base__info-icon") %>Qualification</span>
          <strong><%= qualification %></strong>
        </div>
        <div class="nurse-card-base__detail-row">
          <span class="nurse-card-base__detail-label"><%- icon("gender", "nurse-card-base__info-icon") %>Gender</span>
          <strong><%= gender %></strong>
        </div>
        <% if (religion) { %>
        <div class="nurse-card-base__detail-row">
          <span class="nurse-card-base__detail-label"><%- icon("user", "nurse-card-base__info-icon") %>Religion</span>
          <strong><%= religion %></strong>
        </div>
        <% } %>
        <div class="nurse-card-base__detail-row">
          <span class="nurse-card-base__detail-label"><%- icon("briefcase", "nurse-card-base__info-icon") %>Experience</span>
          <strong><%= experienceLabel %></strong>
        </div>
        <div class="nurse-card-base__detail-row">
          <span class="nurse-card-base__detail-label"><%- icon("location", "nurse-card-base__info-icon") %>City</span>
          <strong><%= city %></strong>
        </div>
      </div>

      <div class="nurse-card-base__details-card">
        <div class="nurse-card-base__detail-row">
          <span class="nurse-card-base__detail-label"><%- icon("clock", "nurse-card-base__info-icon") %>Duty Type</span>
          <strong><%= dutyType %></strong>
        </div>
        <% if (heightValue) { %>
        <div class="nurse-card-base__detail-row">
          <span class="nurse-card-base__detail-label"><%- icon("height", "nurse-card-base__info-icon") %>Height</span>
          <strong><%= heightValue %></strong>
        </div>
        <% } %>
        <% if (weightValue) { %>
        <div class="nurse-card-base__detail-row">
          <span class="nurse-card-base__detail-label"><%- icon("weight", "nurse-card-base__info-icon") %>Weight</span>
          <strong><%= weightValue %></strong>
        </div>
        <% } %>
        <div class="nurse-card-base__detail-row">
          <span class="nurse-card-base__detail-label"><%- icon("availability", "nurse-card-base__info-icon") %>Availability</span>
          <strong><%= availabilityValue %></strong>
        </div>
      </div>
    </section>

    <section class="nurse-card-base__section">
      <div class="nurse-card-base__section-pill">
        <%- icon("language", "nurse-card-base__pill-icon") %>
        <span>Languages</span>
      </div>
      <div class="nurse-card-base__language-line">
        <% if (languages.length) { %>
          <%= languages.join(", ") %>
        <% } else { %>
          Not specified
        <% } %>
      </div>
    </section>

    <section class="nurse-card-base__section">
      <div class="nurse-card-base__section-pill nurse-card-base__section-pill--skills">
        <%- icon("verified", "nurse-card-base__pill-icon") %>
        <span>Skills</span>
      </div>
      <div class="nurse-card-base__skills-list">
        <% if (skills.length) { %>
          <% skills.forEach((item) => { %>
            <span class="nurse-card-base__skill-chip">
              <span class="nurse-card-base__skill-icon">
                <%- icon(skillIconName(item), "nurse-card-base__mini-icon") %>
              </span>
              <span><%= item %></span>
            </span>
          <% }) %>
        <% } else { %>
          <span class="nurse-card-base__skill-chip">
            <span class="nurse-card-base__skill-icon"><%- icon("verified", "nurse-card-base__mini-icon") %></span>
            <span>General Nursing</span>
          </span>
        <% } %>
      </div>
    </section>

    <% if (showContactSection) { %>
      <section class="nurse-card-base__contact-row">
        <div class="nurse-card-base__phone-card">
          <span class="nurse-card-base__phone-icon"><%- icon("phone", "nurse-card-base__pill-icon") %></span>
          <div class="nurse-card-base__phone-copy">
            <% if (contactLabel) { %>
              <span class="nurse-card-base__phone-note"><%= contactLabel %></span>
            <% } %>
            <strong><%= formattedPhoneNumber || "Phone not shared" %></strong>
          </div>
        </div>

        <% if (contactLink) { %>
          <a
            href="<%= contactLink %>"
            class="nurse-card-base__whatsapp-btn"
            <%= openContactInNewTab ? 'target="_blank" rel="noopener noreferrer"' : '' %>
          >
            <%- icon("phone", "nurse-card-base__pill-icon") %>
            <span><%= contactButtonLabel %></span>
          </a>
        <% } else { %>
          <button type="button" class="nurse-card-base__whatsapp-btn is-disabled" disabled>
            <%- icon("phone", "nurse-card-base__pill-icon") %>
            <span><%= contactButtonLabel %></span>
          </button>
        <% } %>
      </section>
    <% } %>

    <% if (documents.length) { %>
    <section class="nurse-card-base__documents" id="documents">
      <% documents.forEach((item) => { %>
        <% const iconName = item.key && item.key.startsWith("aadhaar")
          ? "aadhaar"
          : (item.key === "medical-fit" ? "medical" : "certificate"); %>
        <a
          class="nurse-card-base__document is-available"
          href="<%= item.href %>"
          target="_blank"
          rel="noopener noreferrer"
          <% if (isPreviewableImage(item.href)) { %>
            data-preview-image="<%= item.href %>"
            data-preview-label="<%= item.label %>"
          <% } %>
        >
          <span class="nurse-card-base__document-copy">
            <span class="nurse-card-base__document-icon"><%- icon(iconName, "nurse-card-base__mini-icon") %></span>
            <span><%= item.label %></span>
          </span>
          <strong>View</strong>
        </a>
      <% }) %>
    </section>
    <% } %>
  </div>

  <footer class="nurse-card-base__footer">
