<%
const resolvedMode = String(typeof mode !== "undefined" ? mode : "compact").trim().toLowerCase() === "id"
  ? "id"
  : "compact";
const nurseName = String((nurse && (nurse.fullName || nurse.full_name)) || "Nurse").trim();
const imageSrc = String(
  (nurse && (
    nurse.profileImageUrl
    || nurse.profile_image_url
    || nurse.profileImagePath
    || nurse.profile_image_path
  )) || "/images/default-avatar.png"
).trim();
const qualification = String(
  (nurse && (
    nurse.qualificationPrimary
    || nurse.qualificationsText
  )) || ""
).trim() || "Nursing";
const experienceYears = Number.parseInt((nurse && (nurse.experienceYears || nurse.experience_years)) || 0, 10) || 0;
const experienceLabel = String(
  (nurse && (
    nurse.experienceText
    || nurse.experienceLabel
  )) || ""
).trim() || `${experienceYears} Years`;
const city = String((nurse && nurse.city) || "").trim() || "Not shared";
const statusLabel = String((nurse && nurse.status) || "").trim();
const isVerified = nurse && (nurse.isVerified === true || String(statusLabel).toLowerCase() === "approved");
const ratingAverage = Number.isFinite(Number(nurse && nurse.ratingAverage)) ? Number(nurse.ratingAverage) : 0;
const compactBadgeLabel = ratingAverage > 0 ? `${ratingAverage.toFixed(1)} Rating` : (isVerified ? "Verified" : "Profile");
const compactBadgeClass = ratingAverage > 0 ? "rating" : (isVerified ? "verified" : "neutral");
const nurseId = Number.parseInt((nurse && nurse.id) || 0, 10);
const profileSlug = String((nurse && (nurse.profileSlug || nurse.profile_slug)) || "").trim();
const profileUrl = profileSlug ? `/nurse/${profileSlug}` : "";
const showQr = typeof showQrCode === "undefined" ? false : showQrCode === true;

function icon(name, className) {
  const cls = className ? ` class="${className}"` : "";
  const icons = {
    verified: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.5 2.2 3.3-.3 1.1 3.1 2.7 1.9-1 3.2 1 3.2-2.7 1.9-1.1 3.1-3.3-.3L12 22l-2.5-2.2-3.3.3-1.1-3.1-2.7-1.9 1-3.2-1-3.2 2.7-1.9 1.1-3.1 3.3.3L12 2z" fill="currentColor" opacity=".18"/><path d="M8.5 12.2l2.1 2.1 5-5.2" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    star: `<svg${cls} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3.6l2.5 5.1 5.7.8-4.1 4 1 5.7-5.1-2.7-5.1 2.7 1-5.7-4.1-4 5.7-.8L12 3.6z"/></svg>`,
    experience: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3l2 4.5L19 8l-3.6 3.3.9 4.8L12 13.9l-4.3 2.2.9-4.8L5 8l5-.5L12 3z" fill="currentColor" opacity=".18"/><path d="M12 5.1l1.3 2.7 3 .4-2.2 2 .5 3-2.6-1.3-2.6 1.3.5-3-2.2-2 3-.4L12 5.1z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>`,
    qualification: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 9.5L12 5l9 4.5L12 14 3 9.5z" fill="currentColor" opacity=".18"/><path d="M6.5 11.5V15c0 1.7 2.4 3 5.5 3s5.5-1.3 5.5-3v-3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M3 9.5L12 5l9 4.5L12 14 3 9.5z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>`,
    location: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s6-5.8 6-11a6 6 0 10-12 0c0 5.2 6 11 6 11z" fill="currentColor" opacity=".16"/><circle cx="12" cy="10" r="2.2" stroke="currentColor" stroke-width="1.8"/><path d="M12 21s6-5.8 6-11a6 6 0 10-12 0c0 5.2 6 11 6 11z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>`,
    qr: `<svg${cls} viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4zM16 14h1v1h-1zM19 14h1v3h-1zM14 19h3v1h-3zM16 16h2v2h-2z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>`
  };

  return icons[name] || icons.verified;
}
%>

<% if (resolvedMode === "id") { %>
<article
  class="nurse-card-id"
  <% if (profileUrl) { %>
  data-card-url="<%= profileUrl %>"
  role="link"
  tabindex="0"
  <% } %>
>
  <div class="nurse-card-id__photo-wrap">
    <img
      src="<%= imageSrc %>"
      alt="<%= nurseName %> profile"
      class="nurse-card-id__photo"
      onerror="this.onerror=null;this.src='/images/default-avatar.png';"
    />
  </div>

  <div class="nurse-card-id__content">
    <div class="nurse-card-id__top">
      <div class="nurse-card-id__brand">
        <img src="/images/prisha-logo.png" alt="Prisha Homecare" onerror="this.style.display='none';" />
        <div>
          <strong>Prisha Homecare</strong>
          <span>Professional Nurse ID</span>
        </div>
      </div>

      <% if (showQr && nurseId > 0 && profileUrl) { %>
      <a
        href="<%= profileUrl %>"
        class="nurse-card-id__qr"
        data-card-action
        aria-label="Open nurse public profile"
      >
        <img src="/api/nurse/<%= nurseId %>/qr" alt="QR code for <%= nurseName %>" loading="lazy" />
        <span><%- icon("qr", "nurse-card-id__qr-icon") %></span>
      </a>
      <% } %>
    </div>

    <div class="nurse-card-id__body">
      <h3 class="nurse-card-id__name"><%= nurseName %></h3>

      <dl class="nurse-card-id__details">
        <div class="nurse-card-id__row">
          <dt><%- icon("experience", "nurse-card-id__detail-icon") %>Experience</dt>
          <dd><%= experienceLabel %></dd>
        </div>
        <div class="nurse-card-id__row">
          <dt><%- icon("qualification", "nurse-card-id__detail-icon") %>Qualification</dt>
          <dd><%= qualification %></dd>
        </div>
        <div class="nurse-card-id__row">
          <dt><%- icon("location", "nurse-card-id__detail-icon") %>City</dt>
          <dd><%= city %></dd>
        </div>
      </dl>
    </div>

    <div class="nurse-card-id__footer">
      <span class="nurse-card-id__status <%= isVerified ? 'verified' : 'neutral' %>">
        <%- icon(isVerified ? "verified" : "star", "nurse-card-id__status-icon") %>
        <%= isVerified ? "Verified Nurse" : compactBadgeLabel %>
      </span>
      <span class="nurse-card-id__footer-copy">Scan QR to view public profile</span>
    </div>
  </div>
</article>
<% } else { %>
<article class="nurse-card-compact">
  <div class="nurse-card-compact__media">
    <img
      src="<%= imageSrc %>"
      alt="<%= nurseName %> profile"
      class="nurse-card-compact__avatar"
      onerror="this.onerror=null;this.src='/images/default-avatar.png';"
    />
    <span class="nurse-card-compact__badge nurse-card-compact__badge--<%= compactBadgeClass %>">
      <span class="nurse-card-compact__badge-icon">
        <%- icon(ratingAverage > 0 ? "star" : "verified", "nurse-card-compact__icon") %>
      </span>
      <span><%= compactBadgeLabel %></span>
    </span>
  </div>

  <div class="nurse-card-compact__content">
    <h3 class="nurse-card-compact__name"><%= nurseName %></h3>

    <div class="nurse-card-compact__meta">
      <div class="nurse-card-compact__meta-item">
        <span class="nurse-card-compact__meta-icon"><%- icon("experience", "nurse-card-compact__icon") %></span>
        <div>
          <small>Experience</small>
          <strong><%= experienceLabel %></strong>
        </div>
      </div>

      <div class="nurse-card-compact__meta-item">
        <span class="nurse-card-compact__meta-icon"><%- icon("qualification", "nurse-card-compact__icon") %></span>
        <div>
          <small>Qualification</small>
          <strong><%= qualification %></strong>
        </div>
      </div>

      <div class="nurse-card-compact__meta-item">
        <span class="nurse-card-compact__meta-icon"><%- icon("location", "nurse-card-compact__icon") %></span>
        <div>
          <small>City</small>
          <strong><%= city %></strong>
        </div>
      </div>
    </div>
  </div>
</article>
<% } %>
