<%
const nurseName = nurse.fullName || "Nurse";
const profileHref = typeof href === "string" ? href.trim() : "";
const showRequest = typeof showRequestButton !== "undefined" && showRequestButton === true;
const showDeleteAction = typeof showDeleteButton !== "undefined" && showDeleteButton === true;
const showUtilityActions = typeof showUtilityButtons === "undefined" ? Boolean(profileHref) : showUtilityButtons === true;
const resolvedCardMode = String(typeof mode !== "undefined" ? mode : "compact").trim().toLowerCase() === "full" ? "full" : "compact";
const profileSlug = String(nurse.profileSlug || nurse.profile_slug || "").trim();
const downloadFileName = `${String(profileSlug || nurse.uniqueId || nurseName || "nurse-card")
  .trim()
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, "-")
  .replace(/^-+|-+$/g, "") || "nurse-card"}.png`;
%>

<article
  class="card nurse-card<%= profileHref ? ' nurse-card--interactive' : '' %>"
  data-nurse-card
  data-card-file-name="<%= downloadFileName %>"
  <% if (profileHref) { %>
  data-card-url="<%= profileHref %>"
  role="link"
  tabindex="0"
  <% } %>
>
  <%- include("./nurse-card-base", {
    nurse,
    mode: resolvedCardMode,
    showQrCode: Boolean(profileSlug),
    showBranding: true,
    showContact: resolvedCardMode === "full",
    showWatermarkOverlay: resolvedCardMode === "full" && !!(nurse.status && String(nurse.status).toLowerCase() !== "approved")
  }) %>

  <% if (profileHref || (showRequest && nurse.isAvailable) || showUtilityActions || showDeleteAction) { %>
  <div class="cta-row nurse-actions nurse-card__actions">
    <% if (profileHref) { %>
    <a href="<%= profileHref %>" class="btn primary" data-card-action>View Profile</a>
    <% } %>
    <% if (showRequest && nurse.isAvailable) { %>
    <a href="/request-care?nurseId=<%= nurse.id %>" class="btn primary" data-card-action>Request This Nurse</a>
    <% } %>
    <% if (showUtilityActions && profileHref) { %>
    <button type="button" class="btn" data-card-action data-share-url="<%= profileHref %>" data-share-title="<%= nurseName %> | Nurse Profile">Share</button>
    <button type="button" class="btn" data-card-action data-download-card>Download</button>
    <% } %>
    <% if (showDeleteAction) { %>
    <form method="POST" action="/agent/nurse/delete" class="nurse-delete-form" data-card-action onsubmit="return confirm('Delete this nurse?');">
      <input type="hidden" name="nurseId" value="<%= nurse.id %>" />
      <% if (nurse.canDelete) { %>
      <button class="btn btn-danger btn-sm" type="submit">Delete</button>
      <% } else { %>
      <button class="btn btn-secondary btn-sm" type="button" disabled>Locked</button>
      <% } %>
    </form>
    <% } %>
  </div>
  <% } %>
</article>
