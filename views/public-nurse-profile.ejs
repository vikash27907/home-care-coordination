<%- include("partials/head", { title, metaTitle, metaDescription }) %>

<section class="public-nurse-hero">
  <article class="public-nurse-card-shell">
    <%- include("partials/nurse-card-base", {
      nurse,
      mode: "full",
      showQrCode: true,
      showBranding: true,
      showContact: true,
      showWatermarkOverlay: !isVerified
    }) %>

    <div class="public-nurse-support">
      <% if (isVerified) { %>
        <p class="public-nurse-note public-nurse-note--verified">Verified by Prisha Home Care</p>
      <% } else { %>
        <p class="public-nurse-note public-nurse-note--pending">This nurse profile is public, but verification is still pending.</p>
      <% } %>

      <div class="public-nurse-extra-grid">
        <div>
          <p class="public-nurse-extra-label">Qualification</p>
          <p class="public-nurse-extra-value"><%= nurse.qualificationsText || "-" %></p>
        </div>
      </div>

      <div class="cta-row public-nurse-actions">
        <a href="/request-care?nurseId=<%= nurse.id %>" class="btn primary">Request Care</a>
        <button type="button" class="btn" data-share-url="/nurse/<%= nurse.profileSlug %>" data-share-title="<%= nurse.fullName %> | Nurse Profile">Share Profile</button>
        <a href="/nurses" class="btn">Back to Directory</a>
      </div>
    </div>
  </article>
</section>

<style>
.public-nurse-hero {
  display: flex;
  justify-content: center;
  padding: 2rem 0 3rem;
}

.public-nurse-card-shell {
  width: min(920px, 100%);
  display: grid;
  gap: 1.4rem;
  background: linear-gradient(145deg, #ffffff, #f4fbf8);
  border: 1px solid #d5ebe0;
  border-radius: 28px;
  padding: 1.5rem;
  box-shadow: 0 24px 60px rgba(16, 61, 44, 0.08);
}

.public-nurse-support {
  display: grid;
  gap: 1rem;
}

.public-nurse-note {
  margin: 0;
  font-weight: 700;
}

.public-nurse-note--verified {
  color: #157347;
}

.public-nurse-note--pending {
  color: #9a3412;
}

.public-nurse-extra-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
}

.public-nurse-extra-label {
  margin: 0 0 0.2rem;
  margin-bottom: 0.2rem;
  font-size: 0.82rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: #55716a;
}

.public-nurse-extra-value {
  margin: 0;
  color: #11332a;
  font-size: 1rem;
}

@media (max-width: 720px) {
  .public-nurse-extra-grid {
    grid-template-columns: 1fr;
  }

  .public-nurse-actions {
    flex-direction: column;
  }

  .public-nurse-actions .btn {
    width: 100%;
  }
}
</style>

<%- include("partials/footer") %>
