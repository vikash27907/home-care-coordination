<%
const currentRole = role || 'guest';
const isAdmin = currentRole === "admin";
const isNurse = currentRole === "nurse";
const isAgent = currentRole === "agent";
const canEditProfile = typeof canEdit !== "undefined" ? Boolean(canEdit) : false;
const canViewCard = isAdmin || isNurse || isAgent;
const contactInfo = contactContext && typeof contactContext === "object" ? contactContext : {};
const cardPhone = String(contactInfo.downloadPhone || contactInfo.displayPhone || contactInfo.phone || "").trim();
const cardEmail = String(contactInfo.displayEmail || contactInfo.email || "").trim();

const nurseId = nurse && nurse.id ? nurse.id : "";
const userId = nurse && (nurse.userId || nurse.user_id) ? (nurse.userId || nurse.user_id) : "";
const fullName = String((nurse && (nurse.fullName || nurse.full_name)) || "Nurse");
const status = String((nurse && (nurse.status || nurse.profileStatus || nurse.profile_status)) || "Pending");
const statusKey = status.toLowerCase();
const isVerified = status === "Approved";
const isDeletedUser = Boolean(nurse && (nurse.userIsDeleted || nurse.user_is_deleted));
const city = String((nurse && nurse.city) || "");
const workCity = String((nurse && (nurse.workCity || nurse.work_city)) || "");
const currentAddress = String((nurse && (nurse.currentAddress || nurse.current_address || nurse.address)) || "");
const gender = String((nurse && nurse.gender) || "Not Specified");
const religion = String((nurse && nurse.religion) || "");
const email = String((nurse && nurse.email) || "");
const phone = String((nurse && (nurse.phoneNumber || nurse.phone_number)) || "");
const experienceYears = Number.parseInt((nurse && (nurse.experienceYears || nurse.experience_years)) || 0, 10) || 0;
const heightText = String((nurse && (nurse.height || nurse.heightText || nurse.height_text)) || "").trim();
const weightInputValue = String(
  (nurse && (
    nurse.weightInput
    || nurse.weightDisplay
    || nurse.weightKg
    || nurse.weight_kg
    || nurse.weight
  )) || ""
).trim();
const referralCode = String((nurse && (nurse.referralCode || nurse.referral_code)) || "");
const profileStatus = String((nurse && (nurse.profileStatus || nurse.profile_status)) || "");
const emailVerified = Boolean(nurse && (nurse.emailVerified || nurse.email_verified));
const profileImage = (nurse && (nurse.profileImageUrl || nurse.profile_image_url || nurse.profileImagePath || nurse.profile_image_path)) || "";
const uniqueId = String((nurse && (nurse.uniqueId || nurse.unique_id)) || "");
const profileSlug = String((nurse && (nurse.profileSlug || nurse.profile_slug)) || "");
const publicProfileUrl = String(contactInfo.profileUrl || (profileSlug ? `/nurse/${profileSlug}` : "")).trim();
const availability = Array.isArray(nurse && nurse.availability) ? nurse.availability : [];
const skills = Array.isArray(nurse && nurse.skills) ? nurse.skills : [];
const qualifications = Array.isArray(nurse && nurse.qualifications) ? nurse.qualifications : [];
const qualificationDetails = qualifications
  .map((item, index) => {
    if (item && typeof item === "object") {
      return {
        key: `qualification-${index}`,
        name: String(item.name || "").trim(),
        certificateUrl: String(
          item.certificate_url
          || item.certificateUrl
          || item.document_url
          || item.documentUrl
          || item.file_url
          || item.fileUrl
          || ""
        ).trim(),
        verified: Boolean(item.verified)
      };
    }
    return {
      key: `qualification-${index}`,
      name: String(item || "").trim(),
      certificateUrl: "",
      verified: false
    };
  })
  .filter((item) => item.name);
const qualificationNames = qualifications
  .map((item) => (item && typeof item === "object" ? item.name : item))
  .map((item) => String(item || "").trim())
  .filter(Boolean);

const skillOptions = [...new Set([
  ...((typeof MASTER_SKILL_OPTIONS !== "undefined" && Array.isArray(MASTER_SKILL_OPTIONS)) ? MASTER_SKILL_OPTIONS : []),
  ...skills
])].filter(Boolean);
const availabilityOptions = [...new Set([
  "8 Hour Shift",
  "12 Hour Shift (Day)",
  "12 Hour Shift (Night)",
  "24 Hour Live-In",
  "One-Time / Few Visits",
  ...availability
])].filter(Boolean);
const qualificationOptions = [...new Set([
  ...((typeof MASTER_QUALIFICATION_OPTIONS !== "undefined" && Array.isArray(MASTER_QUALIFICATION_OPTIONS)) ? MASTER_QUALIFICATION_OPTIONS : []),
  ...qualificationNames
])].filter(Boolean);
const CURRENT_STATUS_OPTIONS = [
  "Available for Work",
  "Currently Working",
  "Open to Opportunities",
  "Not Available"
];
function normalizeCurrentStatus(value) {
  const clean = String(value || "").trim();
  if (!clean) return "";
  const key = clean.toLowerCase();
  if (key === "open for work" || key === "available" || key === "available for work") return "Available for Work";
  if (key === "currently working") return "Currently Working";
  if (key === "working need change" || key === "working but looking for change" || key === "open to opportunities") return "Open to Opportunities";
  if (key === "not available" || key === "unavailable") return "Not Available";
  return CURRENT_STATUS_OPTIONS.includes(clean) ? clean : "";
}
const currentStatusRaw = String(
  (nurse && (
    nurse.currentStatus
    || nurse.current_status
  )) || ""
);
const currentStatus = normalizeCurrentStatus(currentStatusRaw);
const currentStatusKey = currentStatus ? currentStatus.toLowerCase().replace(/\s+/g, "-") : "";
const qualificationsText = qualifications
  .map((item) => (item && typeof item === "object" ? item.name : item))
  .map((item) => String(item || "").trim())
  .filter(Boolean)
  .join(", ");
const cardImage = profileImage || "/images/default-avatar.png";

const aadhaarRaw = String(
  (nurse && (nurse.aadhaarNumber || nurse.aadharNumber || nurse.aadhaar_number || nurse.aadhar_number)) || ""
).replace(/\D/g, "");
const aadhaarFrontUrl = String(
  (nurse && (
    nurse.aadhaarFrontUrl
    || nurse.aadharFrontUrl
    || nurse.aadhaar_front_url
    || nurse.aadhar_front_url
    || nurse.aadharImageUrl
    || nurse.aadhar_image_url
    || nurse.aadhaarImageUrl
    || nurse.aadhaar_image_url
    || nurse.aadhaarCardUrl
    || nurse.aadhaar_card_url
    || nurse.aadharCardUrl
    || nurse.aadhar_card_url
  )) || ""
).trim();
const aadhaarBackUrl = String(
  (nurse && (
    nurse.aadhaarBackUrl
    || nurse.aadharBackUrl
    || nurse.aadhaar_back_url
    || nurse.aadhar_back_url
  )) || ""
).trim();
const aadhaarPrimaryUrl = String(
  (nurse && (
    nurse.aadharImageUrl
    || nurse.aadhar_image_url
    || nurse.aadhaarImageUrl
    || nurse.aadhaar_image_url
    || nurse.aadhaarFrontUrl
    || nurse.aadharFrontUrl
    || nurse.aadhaar_front_url
    || nurse.aadhar_front_url
    || nurse.aadhaarCardUrl
    || nurse.aadhaar_card_url
    || nurse.aadharCardUrl
    || nurse.aadhar_card_url
    || nurse.aadhaarBackUrl
    || nurse.aadharBackUrl
    || nurse.aadhaar_back_url
    || nurse.aadhar_back_url
  )) || ""
).trim();
const hasAadhaarFront = Boolean(aadhaarFrontUrl);
const hasAadhaarBack = Boolean(aadhaarBackUrl);
const hasAnyAadhaar = hasAadhaarFront || hasAadhaarBack;
const qualificationDocuments = qualificationDetails.filter((item) => item.certificateUrl);
function isPreviewableImage(url) {
  return /\.(png|jpe?g|webp|gif|bmp|svg)(\?.*)?$/i.test(String(url || "").trim());
}
function isPdfDocument(url) {
  return /\.pdf(\?.*)?$/i.test(String(url || "").trim());
}
function getDocumentLinkLabel(url) {
  if (isPreviewableImage(url)) return "View Image";
  if (isPdfDocument(url)) return "View PDF";
  return "Download Document";
}
function maskAadhar(value) {
  if (!value || value.length < 4) return "XXXX-XXXX-XXXX";
  return "XXXX-XXXX-" + value.slice(-4);
}
const aadhaarDisplay = isAdmin ? (aadhaarRaw || "Not provided") : maskAadhar(aadhaarRaw);

const editAction = isAdmin
  ? `/admin/nurses/${nurseId}/update`
  : (isAgent ? `/agent/nurses/${nurseId}/update` : "/nurse/profile/basic-edit");
const backLink = isAdmin ? "/admin/nurses" : (isAgent ? "/agent/dashboard?tab=staff" : "");
const backLabel = isAdmin ? "Back to Nurses" : (isAgent ? "Back to Staff" : "");
const safeCurrentPath = typeof currentPath === "string" ? currentPath : "";
const unifiedAssetsAction = String((typeof assetsUpdateAction !== "undefined" && assetsUpdateAction) || `/nurse/${nurseId}/update-assets`);
const unifiedAssetsRedirectTo = String(
  (typeof assetsRedirectTo !== "undefined" && assetsRedirectTo)
  || (isAdmin ? `/admin/user/view/nurse/${nurseId}` : (isAgent ? `/agent/nurses/${nurseId}` : "/nurse/profile"))
);
%>

<section
  class="nurse-profile-shell"
  id="nurseProfileShell"
  data-has-aadhar-image="<%= aadhaarPrimaryUrl ? 'true' : 'false' %>"
>
  <% if (backLink) { %>
    <a class="np-back-link" href="<%= backLink %>"><%= backLabel %></a>
  <% } %>

  <% if (isNurse) { %>
    <nav class="np-quick-nav">
      <a href="/nurse/profile" class="np-quick-link <%= safeCurrentPath.startsWith('/nurse/profile') ? 'active' : '' %>">
        Profile
      </a>
      <a href="/request-care" class="np-quick-link <%= safeCurrentPath.startsWith('/request-care') ? 'active' : '' %>">
        Find Jobs
      </a>
      <a href="/nurse/care-requests" class="np-quick-link <%= safeCurrentPath.startsWith('/nurse/care-requests') ? 'active' : '' %>">
        My Jobs
      </a>
    </nav>
  <% } %>

  <% if (canEditProfile) { %>
    <form
      action="<%= unifiedAssetsAction %>"
      method="POST"
      enctype="multipart/form-data"
      id="assetUploadForm"
      class="np-hidden-upload-form"
    >
      <input type="hidden" name="redirectTo" value="<%= unifiedAssetsRedirectTo %>">
      <input
        type="file"
        id="npProfileAssetInput"
        name="profileImage"
        accept="image/jpeg,image/png,image/webp"
      >
      <input
        type="file"
        id="npAadhaarFrontAssetInput"
        name="aadhaarFront"
        accept="image/jpeg,image/png,image/webp,.pdf,application/pdf"
      >
      <input
        type="file"
        id="npAadhaarBackAssetInput"
        name="aadhaarBack"
        accept="image/jpeg,image/png,image/webp,.pdf,application/pdf"
      >
      <input type="hidden" name="qualificationName" id="npQualificationNameInput" value="">
    </form>
  <% } %>

  <article class="np-card np-header-card">
    <div class="np-header-left">
      <div class="np-avatar-shell">
        <div class="np-avatar-wrap <%= canEditProfile ? 'is-editable' : '' %>">
          <% if (profileImage) { %>
            <img
              src="<%= profileImage %>"
              alt="<%= fullName %>"
              class="np-avatar"
              onerror="console.error('Failed to load nurse profile image:', this.currentSrc || this.src);this.onerror=null;this.src='/images/default-avatar.png';"
              data-preview-image="<%= profileImage %>"
              data-preview-label="<%= fullName %> profile photo"
              role="button"
              tabindex="0"
            >
          <% } else { %>
            <span class="np-avatar-fallback"><%= fullName.charAt(0).toUpperCase() %></span>
          <% } %>

          <% if (canEditProfile) { %>
            <button
              type="button"
              class="np-avatar-overlay"
              data-asset-trigger="profileImage"
              aria-label="Edit profile image"
            >
              Edit
            </button>
          <% } %>
        </div>
      </div>

      <div class="np-header-copy">
        <h1><%= fullName %></h1>
        <div class="np-badges">
          <span class="np-badge status <%= statusKey %>"><%= status %></span>
          <% if (isDeletedUser) { %>
            <span class="np-badge archived">Archived User</span>
          <% } %>
          <% if (currentStatus) { %>
            <span class="status-badge <%= currentStatus.toLowerCase().replace(/\s/g,'-') %>">
              <%= currentStatus %>
            </span>
          <% } %>
        </div>
        <p class="np-meta">
          Experience: <strong><%= experienceYears %> years</strong>
          <% if (referralCode) { %>
            <span class="np-dot"></span>
            Referral: <code><%= referralCode %></code>
          <% } %>
        </p>
      </div>
    </div>

    <% if (canEditProfile || canViewCard) { %>
      <div class="np-header-actions">
        <% if (canEditProfile) { %>
          <button type="button" class="btn primary" id="npToggleEditBtn">Edit Profile</button>
        <% } %>
        <% if (canViewCard) { %>
          <button type="button" class="btn" id="npViewIdCardBtn">View Card</button>
        <% } %>
      </div>
    <% } %>
  </article>

  <div class="id-card-modal" id="npIdCardModal" aria-hidden="true">
    <div class="id-card-container">
      <button type="button" class="close-card" id="npCloseIdCardBtn" aria-label="Close ID card">&times;</button>

      <%- include("../partials/nurse-card-image", {
        nurse,
        cardId: "nurse-id-card",
        profileUrl: publicProfileUrl,
        contactContext: {
          ...contactInfo,
          downloadPhone: cardPhone,
          displayEmail: cardEmail
        }
      }) %>

    <div class="card-actions">
      <button
        type="button"
        class="btn"
        data-card-action
        data-card-share="nurse-id-card"
        data-share-url="<%= publicProfileUrl %>"
        data-share-name="<%= fullName %>"
        data-share-intro="This is my profile"
      >Share</button>
      <button
        type="button"
        class="btn"
        data-card-action
        data-card-download="nurse-id-card"
      >Download</button>
    </div>
    </div>
  </div>

  <% if (canEditProfile) { %>
  <form
    id="profileForm"
    method="POST"
    action="<%= editAction %>"
    class="np-profile-form"
    <%- isNurse ? 'enctype="multipart/form-data"' : "" %>
  >
    <% if (isAdmin) { %>
      <input type="hidden" name="statusFilter" value="">
    <% } %>
  <% } %>

    <article class="np-card np-tabs-card">
      <div class="np-tabs">
        <button type="button" class="np-tab-btn active" data-np-tab-target="personal">Personal</button>
        <button type="button" class="np-tab-btn" data-np-tab-target="professional">Professional</button>
        <button type="button" class="np-tab-btn" data-np-tab-target="access"><%= isAgent ? "Access" : "Security" %></button>
      </div>
    </article>

    <section class="np-tab-panel np-section-block" id="personal" data-np-section>
      <article class="np-card">
        <h2>Basic Information</h2>
        <div class="np-grid">
          <div class="np-field">
            <label>Full Name</label>
            <div class="np-view"><%= fullName || "-" %></div>
            <% if (canEditProfile) { %>
              <input class="np-edit-field" type="text" name="fullName" value="<%= fullName %>">
            <% } %>
          </div>

          <div class="np-field">
            <label>Email</label>
            <div class="np-view"><%= email || "-" %></div>
            <% if (isAdmin) { %>
              <input class="np-edit-field" type="email" name="email" value="<%= email %>" required>
            <% } %>
          </div>

          <div class="np-field">
            <label>Mobile</label>
            <div class="np-view"><%= phone || "-" %></div>
            <% if (canEditProfile) { %>
              <input class="np-edit-field" type="text" name="phoneNumber" value="<%= phone %>" placeholder="10-digit mobile number">
            <% } %>
          </div>

          <div class="np-field">
            <label>Gender</label>
            <div class="np-view"><%= gender || "-" %></div>
            <% if (canEditProfile) { %>
              <select class="np-edit-field" name="gender">
                <option value="Not Specified" <%= gender === "Not Specified" ? "selected" : "" %>>Not Specified</option>
                <option value="Female" <%= gender === "Female" ? "selected" : "" %>>Female</option>
                <option value="Male" <%= gender === "Male" ? "selected" : "" %>>Male</option>
                <option value="Other" <%= gender === "Other" ? "selected" : "" %>>Other</option>
              </select>
            <% } %>
          </div>

          <div class="np-field">
            <label>Religion</label>
            <div class="np-view"><%= religion || "-" %></div>
            <% if (canEditProfile) { %>
              <input class="np-edit-field" type="text" name="religion" value="<%= religion %>" maxlength="80" placeholder="Religion">
            <% } %>
          </div>

          <div class="np-field">
            <label>City</label>
            <div class="np-view"><%= city || "-" %></div>
            <% if (canEditProfile) { %>
              <input class="np-edit-field" type="text" name="city" value="<%= city %>">
            <% } %>
          </div>

          <div class="np-field">
            <label>Work City</label>
            <div class="np-view"><%= workCity || "-" %></div>
            <% if (canEditProfile) { %>
              <input class="np-edit-field" type="text" name="workCity" value="<%= workCity %>">
            <% } %>
          </div>

          <div class="np-field np-span-2">
            <label>Current Address</label>
            <div class="np-view"><%= currentAddress || "-" %></div>
            <% if (canEditProfile) { %>
              <textarea class="np-edit-field" name="currentAddress" rows="3"><%= currentAddress %></textarea>
            <% } %>
          </div>

          <div class="np-field">
            <label>Aadhaar</label>
            <div class="np-view"><%= aadhaarDisplay %></div>
            <% if (canEditProfile) { %>
              <input
                class="np-edit-field"
                type="text"
                name="aadharNumber"
                value="<%= aadhaarRaw %>"
                maxlength="12"
                pattern="\d{12}"
                inputmode="numeric"
                placeholder="12-digit Aadhaar"
              >
            <% } %>
          </div>

        </div>
      </article>

      <% if (hasAnyAadhaar || canEditProfile) { %>
      <article class="np-card np-doc-section-card">
        <div class="np-section-head">
          <div>
            <h2>Aadhaar Card</h2>
            <p class="np-muted">Only uploaded Aadhaar files are shown here. Add or replace individual sides whenever needed.</p>
          </div>
        </div>

        <div class="np-document-group">
          <% if (hasAadhaarFront || canEditProfile) { %>
          <div class="np-doc-item">
            <div class="np-doc-copy">
              <span class="np-doc-label">Front Side</span>
              <span class="np-doc-note"><%= hasAadhaarFront ? "Uploaded" : "Upload front side" %></span>
            </div>
            <div class="np-doc-actions">
              <% if (hasAadhaarFront) { %>
                <a
                  class="np-doc-link"
                  href="<%= aadhaarFrontUrl %>"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Open Aadhaar front document"
                  <% if (isPreviewableImage(aadhaarFrontUrl)) { %>
                    data-preview-image="<%= aadhaarFrontUrl %>"
                    data-preview-label="Aadhaar front"
                  <% } %>
                ><%= getDocumentLinkLabel(aadhaarFrontUrl) %></a>
              <% } %>
              <% if (canEditProfile) { %>
                <button type="button" class="np-doc-button" data-asset-trigger="aadhaarFront">Upload / Replace</button>
              <% } %>
            </div>
          </div>
          <% } %>

          <% if (hasAadhaarBack || canEditProfile) { %>
          <div class="np-doc-item">
            <div class="np-doc-copy">
              <span class="np-doc-label">Back Side</span>
              <span class="np-doc-note"><%= hasAadhaarBack ? "Uploaded" : "Upload back side" %></span>
            </div>
            <div class="np-doc-actions">
              <% if (hasAadhaarBack) { %>
                <a
                  class="np-doc-link"
                  href="<%= aadhaarBackUrl %>"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Open Aadhaar back document"
                  <% if (isPreviewableImage(aadhaarBackUrl)) { %>
                    data-preview-image="<%= aadhaarBackUrl %>"
                    data-preview-label="Aadhaar back"
                  <% } %>
                ><%= getDocumentLinkLabel(aadhaarBackUrl) %></a>
              <% } %>
              <% if (canEditProfile) { %>
                <button type="button" class="np-doc-button" data-asset-trigger="aadhaarBack">Upload / Replace</button>
              <% } %>
            </div>
          </div>
          <% } %>
        </div>
      </article>
      <% } %>
    </section>

    <section class="np-tab-panel np-section-block" id="professional" data-np-section>
      <article class="np-card">
        <h2>Professional Details</h2>
        <div class="np-grid">
          <div class="np-field">
            <label>Experience (Years)</label>
            <div class="np-view"><%= experienceYears %></div>
            <% if (canEditProfile) { %>
              <input class="np-edit-field" type="number" min="0" max="60" name="experienceYears" value="<%= experienceYears %>">
            <% } %>
          </div>

          <div class="np-field">
            <label>Height</label>
            <div class="np-view"><%= heightText || "-" %></div>
            <% if (canEditProfile) { %>
              <input class="np-edit-field" type="text" name="height" value="<%= heightText %>" maxlength="20" placeholder="e.g. 5'6 or 167 cm">
            <% } %>
          </div>

          <div class="np-field">
            <label>Weight</label>
            <div class="np-view"><%= weightInputValue ? `${weightInputValue}${/kg$/i.test(weightInputValue) ? "" : " kg"}` : "-" %></div>
            <% if (canEditProfile) { %>
              <input class="np-edit-field" type="text" name="weight" value="<%= weightInputValue %>" maxlength="20" placeholder="e.g. 60 kg">
            <% } %>
          </div>

          <div class="np-field">
            <label>Current Status</label>
            <div class="np-view">
              <% if (currentStatus) { %>
                <span class="status-badge <%= currentStatusKey %>"><%= currentStatus %></span>
              <% } else { %>
                <span>-</span>
              <% } %>
            </div>
            <% if (canEditProfile) { %>
              <select class="np-edit-field" name="current_status" required>
                <option value="Available for Work" <%= currentStatus === "Available for Work" ? "selected" : "" %>>Available for Work</option>
                <option value="Currently Working" <%= currentStatus === "Currently Working" ? "selected" : "" %>>Currently Working</option>
                <option value="Open to Opportunities" <%= currentStatus === "Open to Opportunities" ? "selected" : "" %>>Open to Opportunities</option>
                <option value="Not Available" <%= currentStatus === "Not Available" ? "selected" : "" %>>Not Available</option>
              </select>
            <% } %>
          </div>

          <div class="np-field np-span-2">
            <label>Skills</label>
            <div id="skillsViewSection" class="np-view np-chip-wrap view-mode">
              <% if (skills.length) { %>
                <% skills.forEach((item) => { %>
                  <span class="np-chip"><%= item %></span>
                <% }) %>
              <% } else { %>
                <span>-</span>
              <% } %>
            </div>
            <% if (canEditProfile) { %>
              <div id="skillsEditSection" class="edit-mode" style="display: none;">
                <input class="np-edit-field" type="hidden" name="skills" value="">
                <div class="np-edit-field np-skill-tags" id="selectedSkillsContainer"></div>
                <input
                  class="np-edit-field np-skill-search"
                  type="text"
                  id="skillSearch"
                  placeholder="Search skills"
                >
                <div class="np-edit-field np-skill-dropdown" id="skillsDropdown"></div>
                <select
                  class="np-edit-field np-multi-select np-skill-select-hidden"
                  id="skillsSelect"
                  name="skills"
                  multiple
                  size="8"
                >
                  <% skillOptions.forEach((item) => { %>
                    <option value="<%= item %>" <%= skills.includes(item) ? "selected" : "" %>><%= item %></option>
                  <% }) %>
                </select>
              </div>
            <% } %>
          </div>

          <div class="np-field np-span-2">
            <label>Qualifications</label>
            <div class="np-view np-chip-wrap">
              <% if (qualificationsText) { %>
                <% qualificationsText.split(",").forEach((item) => { %>
                  <span class="np-chip"><%= item.trim() %></span>
                <% }) %>
              <% } else { %>
                <span>-</span>
              <% } %>
            </div>
            <% if (canEditProfile) { %>
              <input class="np-edit-field" type="hidden" name="qualifications" value="">
              <select class="np-edit-field np-multi-select" name="qualifications" multiple size="6">
                <% qualificationOptions.forEach((item) => { %>
                  <option value="<%= item %>" <%= qualificationNames.includes(item) ? "selected" : "" %>><%= item %></option>
                <% }) %>
              </select>
            <% } %>
          </div>

          <div class="np-field np-span-2">
            <label>Availability</label>
            <div id="availabilityViewSection" class="np-view np-chip-wrap view-mode">
              <% if (availability.length) { %>
                <% availability.forEach((item) => { %>
                  <span class="np-chip"><%= item %></span>
                <% }) %>
              <% } else { %>
                <span>-</span>
              <% } %>
            </div>
            <% if (canEditProfile) { %>
              <div id="availabilityEditSection" class="edit-mode" style="display: none;">
                <div id="availabilityTags" class="np-edit-field np-availability-tags"></div>

                <div id="availabilityOptions" class="np-edit-field np-availability-options">
                  <button type="button" class="availability-option">8 Hour Shift</button>
                  <button type="button" class="availability-option">12 Hour Shift (Day)</button>
                  <button type="button" class="availability-option">12 Hour Shift (Night)</button>
                  <button type="button" class="availability-option">24 Hour Live-In</button>
                  <button type="button" class="availability-option">One-Time / Few Visits</button>
                </div>

                <input class="np-edit-field" type="hidden" name="availability[]" value="">
                <select id="availabilitySelect" class="np-edit-field np-availability-select-hidden" name="availability[]" multiple hidden>
                  <option value="8 Hour Shift" <%= availability.includes("8 Hour Shift") ? "selected" : "" %>>8 Hour Shift</option>
                  <option value="12 Hour Shift (Day)" <%= availability.includes("12 Hour Shift (Day)") ? "selected" : "" %>>12 Hour Shift (Day)</option>
                  <option value="12 Hour Shift (Night)" <%= availability.includes("12 Hour Shift (Night)") ? "selected" : "" %>>12 Hour Shift (Night)</option>
                  <option value="24 Hour Live-In" <%= availability.includes("24 Hour Live-In") ? "selected" : "" %>>24 Hour Live-In</option>
                  <option value="One-Time / Few Visits" <%= availability.includes("One-Time / Few Visits") ? "selected" : "" %>>One-Time / Few Visits</option>
                </select>
              </div>
            <% } %>
          </div>

          <div class="np-field">
            <label>Referral Code</label>
            <div class="np-view"><%= referralCode || "-" %></div>
            <% if (isAdmin) { %>
              <input class="np-edit-field" type="text" name="referralCode" value="<%= referralCode %>">
            <% } %>
          </div>

          <% if (isAdmin) { %>
          <div class="np-field">
            <label>Status</label>
            <div class="np-view"><%= status %></div>
            <select class="np-edit-field" name="status">
              <option value="Pending" <%= status === "Pending" ? "selected" : "" %>>Pending</option>
              <option value="Approved" <%= status === "Approved" ? "selected" : "" %>>Approved</option>
              <option value="Rejected" <%= status === "Rejected" ? "selected" : "" %>>Rejected</option>
            </select>
          </div>

          <div class="np-field">
            <label>Profile Status</label>
            <div class="np-view"><%= profileStatus || "-" %></div>
            <input class="np-edit-field" type="text" name="profileStatus" value="<%= profileStatus %>">
          </div>
          <% } %>
        </div>

        <% if (isAdmin && status === "Pending") { %>
        <div class="np-inline-actions">
          <button type="submit" name="statusAction" value="Approved" class="btn primary">Approve Nurse</button>
          <button type="submit" name="statusAction" value="Rejected" class="btn danger">Reject Nurse</button>
        </div>
        <% } %>

      </article>

      <% if (qualificationDocuments.length || (canEditProfile && qualificationDetails.length)) { %>
      <article class="np-card np-doc-section-card">
        <div class="np-section-head">
          <div>
            <h2>Qualifications & Certificates</h2>
            <p class="np-muted">Qualification documents appear only when a certificate has been uploaded for that qualification.</p>
          </div>
        </div>

        <% if (qualificationDetails.length) { %>
          <div class="np-document-group">
            <% qualificationDetails.forEach((item, index) => { %>
              <% if (item.certificateUrl || canEditProfile) { %>
              <div class="np-doc-item">
                <div class="np-doc-copy">
                  <span class="np-doc-label"><%= item.name %></span>
                  <span class="np-doc-note"><%= item.certificateUrl ? "Uploaded" : "Upload certificate" %></span>
                </div>
                <div class="np-doc-actions">
                  <% if (item.certificateUrl) { %>
                    <a
                      class="np-doc-link"
                      href="<%= item.certificateUrl %>"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label="Open <%= item.name %> certificate"
                      <% if (isPreviewableImage(item.certificateUrl)) { %>
                        data-preview-image="<%= item.certificateUrl %>"
                        data-preview-label="<%= item.name %> certificate"
                      <% } %>
                    ><%= getDocumentLinkLabel(item.certificateUrl) %></a>
                  <% } %>
                  <% if (canEditProfile) { %>
                    <button
                      type="button"
                      class="np-doc-button"
                      onclick="triggerQualificationUpload(<%= index %>)"
                    >
                      <%= item.certificateUrl ? "Edit" : "Upload" %>
                    </button>
                    <input
                      type="file"
                      id="qualInput_<%= index %>"
                      name="qualificationDocument"
                      form="assetUploadForm"
                      data-name="<%= item.name %>"
                      accept="image/jpeg,image/png,image/webp,.pdf,application/pdf"
                      style="position:absolute; left:-9999px;"
                      onchange="submitQualification(this)"
                    >
                  <% } %>
                </div>
              </div>
              <% } %>
            <% }) %>
          </div>
        <% } %>
      </article>
      <% } %>
    </section>

    <section class="np-tab-panel np-section-block" id="access" data-np-section>
      <article class="np-card">
        <h2>Security</h2>
        <div class="np-grid">
          <div class="np-field">
            <label>Email Verification</label>
            <div class="np-view">
              <span class="np-badge <%= emailVerified ? "verified" : "unverified" %>">
                <%= emailVerified ? "Verified" : "Not Verified" %>
              </span>
            </div>
            <% if (isAdmin) { %>
              <select class="np-edit-field" name="emailVerified">
                <option value="true" <%= emailVerified ? "selected" : "" %>>Verified</option>
                <option value="false" <%= !emailVerified ? "selected" : "" %>>Not Verified</option>
              </select>
            <% } %>
          </div>
        </div>

        <% if (canEditProfile) { %>
          <input
            type="hidden"
            name="redirectTo"
            value="<%= isAdmin ? `/admin/user/view/nurse/${nurseId}` : (isAgent ? `/agent/nurses/${nurseId}` : '/nurse/profile') %>"
          >
        <% } %>

<% if (isAdmin && userId) { %>
          <div class="np-security-actions">
            <button type="submit" class="btn warning" formaction="/admin/user/<%= userId %>/reset-password" formmethod="POST">
              Reset Password
            </button>

            <div class="np-pass-form">
              <div class="np-password-input">
                <input
                  type="password"
                  name="newPassword"
                  id="adminNursePasswordInput"
                  placeholder="New password"
                  autocomplete="new-password"
                >
                <button
                  type="button"
                  class="np-password-toggle"
                  data-password-toggle="#adminNursePasswordInput"
                  aria-controls="adminNursePasswordInput"
                  aria-label="Show password"
                  aria-pressed="false"
                >
                  Show
                </button>
              </div>
              <button type="submit" class="btn primary" formaction="/admin/user/<%= userId %>/change-password" formmethod="POST">
                Change Password
              </button>
            </div>

            <button
              type="submit"
              class="btn danger"
              formaction="/admin/nurses/<%= nurseId %>/delete"
              formmethod="POST"
              name="deleteRedirectTo"
              value="/admin/nurses"
              onclick="return confirm('Delete this nurse permanently? This removes the account and related records.');"
            >
              Delete Nurse
            </button>
          </div>
        <% } %>

        <% if (isNurse) { %>
          <div class="np-security-actions">
            <div class="np-pass-form">
              <input type="password" name="currentPassword" placeholder="Current password">
              <input type="password" name="newPassword" placeholder="New password">
              <input type="password" name="confirmPassword" placeholder="Confirm new password">
              <button type="submit" class="btn primary" formaction="/nurse/password/change" formmethod="POST">
                Change Password
              </button>
            </div>
          </div>
        <% } %>

        <% if (isAgent) { %>
          <p class="np-muted">Security controls are not available for agent role.</p>
        <% } %>
      </article>
    </section>

    <% if (canEditProfile) { %>
      <div class="np-edit-actions" id="npEditActions">
        <button type="button" class="btn" id="npCancelEditBtn">Cancel</button>
        <button type="submit" class="btn primary" form="profileForm">Save</button>
      </div>
    </form>
    <% } %>
</section>

