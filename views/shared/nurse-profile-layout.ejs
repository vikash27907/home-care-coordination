  align-items: center;
  gap: 0.35rem;
  border: 1px solid #c9dff0;
  border-radius: 999px;
  background: #edf5fc;
  color: #164a77;
  font-size: 0.82rem;
  padding: 0.24rem 0.34rem 0.24rem 0.6rem;
}

.remove-availability {
  width: 24px;
  height: 24px;
  border: none;
  border-radius: 999px;
  background: #d9ecfa;
  color: #0f4f83;
  font-size: 1rem;
  line-height: 1;
  cursor: pointer;
}

.remove-availability:hover {
  background: #c4e2f8;
}

.availability-option {
  border: 1px solid #c6dae8;
  border-radius: 10px;
  background: #ffffff;
  color: #11304f;
  padding: 0.5rem 0.7rem;
  cursor: pointer;
  font: inherit;
}

.availability-option:hover {
  background: #edf5fc;
}

.availability-option.is-selected {
  background: #d9ecfa;
  border-color: #8ec1e8;
  color: #0f4f83;
}

.qualification-module {
  margin-top: 0.9rem;
}

.qualification-item {
  border: 1px solid #d9e7f3;
  border-radius: 12px;
  padding: 0.8rem;
  margin-top: 0.6rem;
  background: #f8fbfe;
}

.qualification-item label {
  text-transform: none;
  letter-spacing: normal;
  color: #11304f;
}

.qualification-item input[type="file"] {
  margin-top: 0.45rem;
  width: 100%;
}

.np-muted {
  color: #5b7388;
  margin: 0.25rem 0 0;
}

.np-edit-actions {
  display: none;
  justify-content: flex-end;
  gap: 0.6rem;
  padding: 0.4rem 0;
}

.id-card-modal {
  display: none;
}

.id-card-modal.is-open {
  display: flex;
}

.card-actions {
  display: flex;
  justify-content: center;
  gap: 0.75rem;
  margin-top: 1rem;
  flex-wrap: wrap;
}

.card-actions .btn[disabled] {
  opacity: 0.55;
  cursor: not-allowed;
}

.nurse-profile-shell.is-editing .np-edit-actions {
  display: flex;
}

.btn.warning {
  border-color: #f0c14b;
  background: #ffe8b3;
  color: #7a4d00;
}

.btn.danger {
  border-color: #ef9a9a;
  background: #ffe4e6;
  color: #9f1239;
}

@media (max-width: 900px) {
  .np-header-card {
    flex-direction: column;
    align-items: flex-start;
  }

  .np-grid {
    grid-template-columns: 1fr;
  }

  .np-span-2 {
    grid-column: auto;
  }

  .np-pass-form {
    grid-template-columns: 1fr;
  }

  .np-password-input {
    grid-column: auto;
  }

  .np-header-actions {
    width: 100%;
  }

  .np-tabs-card {
    top: 0.6rem;
  }

  .np-doc-item,
  .np-doc-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .np-doc-link,
  .np-doc-button {
    width: 100%;
  }
}
</style>

<script src="/vendor/html-to-image.js"></script>
<script src="/js/agent-dashboard.js"></script>
<script>
(() => {
  const shell = document.getElementById("nurseProfileShell");
  if (!shell) return;

  const tabButtons = Array.from(shell.querySelectorAll(".np-tab-btn"));
  const pageSections = Array.from(shell.querySelectorAll("[data-np-section]"));
  const setActiveTab = (targetId) => {
    tabButtons.forEach((item) => {
      item.classList.toggle("active", item.getAttribute("data-np-tab-target") === targetId);
    });
  };
  const getCurrentSectionId = () => {
    let currentId = pageSections[0] ? pageSections[0].id : "";
    pageSections.forEach((section) => {
      if (!(section instanceof HTMLElement)) return;
      if (window.scrollY >= (section.offsetTop - 150)) {
        currentId = section.id;
      }
    });
    return currentId;
  };

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const targetId = String(button.getAttribute("data-np-tab-target") || "").trim();
      const targetSection = targetId ? document.getElementById(targetId) : null;
      if (!(targetSection instanceof HTMLElement)) return;
      setActiveTab(targetId);
      targetSection.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });

  const syncActiveTabWithScroll = () => {
    const currentId = getCurrentSectionId();
    if (currentId) {
      setActiveTab(currentId);
    }
  };
  window.addEventListener("scroll", syncActiveTabWithScroll, { passive: true });
  window.addEventListener("resize", syncActiveTabWithScroll);
  syncActiveTabWithScroll();

  const editButton = document.getElementById("npToggleEditBtn");
  const viewIdCardButton = document.getElementById("npViewIdCardBtn");
  const idCardModal = document.getElementById("npIdCardModal");
  const closeIdCardButton = document.getElementById("npCloseIdCardBtn");
  const cancelButton = document.getElementById("npCancelEditBtn");
  const profileForm = document.getElementById("profileForm");
  const selectedSkillsContainer = document.getElementById("selectedSkillsContainer");
  const skillSearchInput = document.getElementById("skillSearch");
  const skillSelect = document.getElementById("skillsSelect");
  const skillsDropdown = document.getElementById("skillsDropdown");
  const availabilityTags = document.getElementById("availabilityTags");
  const availabilitySelect = document.getElementById("availabilitySelect");
  const availabilityOptionButtons = shell.querySelectorAll(".availability-option");
  const assetForm = document.getElementById("assetUploadForm");
  const assetProfileInput = document.getElementById("npProfileAssetInput");
  const assetAadhaarFrontInput = document.getElementById("npAadhaarFrontAssetInput");
  const assetAadhaarBackInput = document.getElementById("npAadhaarBackAssetInput");
  const qualificationNameInput = document.getElementById("npQualificationNameInput");
  const assetTriggers = shell.querySelectorAll("[data-asset-trigger]");
  const passwordToggleButtons = shell.querySelectorAll("[data-password-toggle]");

  passwordToggleButtons.forEach((button) => {
    if (!(button instanceof HTMLButtonElement)) return;
    const selector = String(button.getAttribute("data-password-toggle") || "").trim();
    const input = selector ? shell.querySelector(selector) : null;
    if (!(input instanceof HTMLInputElement)) return;
    button.addEventListener("click", () => {
      const shouldShow = input.type === "password";
      input.type = shouldShow ? "text" : "password";
      button.textContent = shouldShow ? "Hide" : "Show";
      button.setAttribute("aria-label", shouldShow ? "Hide password" : "Show password");
      button.setAttribute("aria-pressed", shouldShow ? "true" : "false");
    });
  });

  let selectedSkills = new Set();
  let selectedAvailability = new Set();
  const normalizeSkillValue = (value) => String(value || "").trim().toLowerCase();
  const getSelectedSkill = (value) => {
    const target = normalizeSkillValue(value);
    if (!target) return null;
    for (const skill of selectedSkills) {
      if (normalizeSkillValue(skill) === target) {
        return skill;
      }
    }
    return null;
  };
  const hasSelectedSkill = (value) => Boolean(getSelectedSkill(value));
  const addSelectedSkill = (value) => {
    const cleanValue = String(value || "").trim();
    if (!cleanValue || hasSelectedSkill(cleanValue)) return false;
    selectedSkills.add(cleanValue);
    return true;
  };
  const removeSelectedSkill = (value) => {
    const existingSkill = getSelectedSkill(value);
    if (!existingSkill) return false;
    selectedSkills.delete(existingSkill);
    return true;
  };
  const ensureSkillOptionExists = (value) => {
    if (!skillSelect) return null;
    const cleanValue = String(value || "").trim();
    if (!cleanValue) return null;

    const existingOption = Array.from(skillSelect.options).find(
      (option) => normalizeSkillValue(option.value) === normalizeSkillValue(cleanValue)
    );
    if (existingOption) return existingOption;

    const newOption = new Option(cleanValue, cleanValue, false, false);
    skillSelect.appendChild(newOption);
    return newOption;
  };
  const updateHiddenSelect = () => {
    if (!skillSelect) return;
    Array.from(skillSelect.options).forEach((option) => {
      option.selected = hasSelectedSkill(option.value);
    });
  };
  const renderSelectedSkills = () => {
    if (!selectedSkillsContainer) return;
    selectedSkillsContainer.innerHTML = "";

    if (!selectedSkills.size) {
      const emptyState = document.createElement("span");
      emptyState.className = "np-skill-tags-empty";
      emptyState.textContent = "No skills selected";
      selectedSkillsContainer.appendChild(emptyState);
      return;
    }

    selectedSkills.forEach((skillName) => {
      const tag = document.createElement("span");
      tag.className = "skill-tag";
      tag.textContent = skillName;

      const removeButton = document.createElement("button");
      removeButton.type = "button";
      removeButton.className = "remove-skill";
      removeButton.textContent = "\u00d7";
      removeButton.setAttribute("aria-label", `Remove ${skillName}`);
      removeButton.addEventListener("click", () => {
        if (!removeSelectedSkill(skillName)) return;
        updateSkillUI();
      });

      tag.appendChild(removeButton);
      selectedSkillsContainer.appendChild(tag);
    });
  };
  const renderSkillsDropdown = () => {
    if (!skillsDropdown || !skillSelect) return;
    skillsDropdown.innerHTML = "";

    const searchTerm = skillSearchInput ? String(skillSearchInput.value || "").trim() : "";
    const termLower = searchTerm.toLowerCase();
    const seen = new Set();
    const optionValues = Array.from(skillSelect.options)
      .map((option) => String(option.value || "").trim())
      .filter(Boolean)
      .filter((value) => {
        const key = normalizeSkillValue(value);
        if (!key || seen.has(key)) return false;
        seen.add(key);
        return true;
      });

    let matchCount = 0;
    optionValues.forEach((skillName) => {
      const matches = !termLower || skillName.toLowerCase().includes(termLower);
      if (!matches) return;
      matchCount += 1;

      const optionButton = document.createElement("button");
      optionButton.type = "button";
      optionButton.className = "np-skill-option";

      if (hasSelectedSkill(skillName)) {
        optionButton.classList.add("is-selected");
        optionButton.textContent = `${skillName} (Selected)`;
        optionButton.disabled = true;
      } else {
        optionButton.textContent = skillName;
        optionButton.addEventListener("click", () => {
          if (!addSelectedSkill(skillName)) return;
          if (skillSearchInput) skillSearchInput.value = "";
          updateSkillUI();
        });
      }

      skillsDropdown.appendChild(optionButton);
    });

    const hasExactSkill = optionValues.some(
      (skillName) => normalizeSkillValue(skillName) === normalizeSkillValue(searchTerm)
    );
    if (!matchCount && searchTerm && !hasExactSkill) {
      const addButton = document.createElement("button");
      addButton.type = "button";
      addButton.className = "np-skill-option add-new";
      addButton.textContent = `Add "${searchTerm}"`;
      addButton.addEventListener("click", () => {
        ensureSkillOptionExists(searchTerm);
        if (!addSelectedSkill(searchTerm)) return;
        if (skillSearchInput) skillSearchInput.value = "";
        updateSkillUI();
      });
      skillsDropdown.appendChild(addButton);
      return;
    }

    if (!skillsDropdown.childElementCount) {
      const noResult = document.createElement("div");
      noResult.className = "np-skill-tags-empty";
      noResult.textContent = "No skills found";
      skillsDropdown.appendChild(noResult);
    }
  };
  const updateSkillUI = () => {
    updateHiddenSelect();
    renderSelectedSkills();
    renderSkillsDropdown();
  };
  const initializeSelectedSkillsFromSelect = () => {
    if (!skillSelect) return;
    selectedSkills = new Set();
    Array.from(skillSelect.options).forEach((option) => {
      if (option.selected) addSelectedSkill(option.value);
    });
    updateSkillUI();
  };
  const syncAvailabilitySelect = () => {
    if (!availabilitySelect) return;
    Array.from(availabilitySelect.options).forEach((option) => {
      option.selected = selectedAvailability.has(option.value);
    });
  };
  const syncAvailabilityButtons = () => {
    if (!availabilityOptionButtons || !availabilityOptionButtons.length) return;
    availabilityOptionButtons.forEach((button) => {
      const value = String(button.textContent || "").trim();
      const isSelected = selectedAvailability.has(value);
      button.classList.toggle("is-selected", isSelected);
      button.setAttribute("aria-pressed", isSelected ? "true" : "false");
    });
  };
  const renderAvailabilityTags = () => {
    if (!availabilityTags) return;
    availabilityTags.innerHTML = "";

    if (!selectedAvailability.size) {
      const emptyState = document.createElement("span");
      emptyState.className = "np-skill-tags-empty";
      emptyState.textContent = "No availability selected";
      availabilityTags.appendChild(emptyState);
      return;
    }

    selectedAvailability.forEach((value) => {
      const tag = document.createElement("span");
      tag.className = "availability-tag";
      tag.appendChild(document.createTextNode(value));

      const removeButton = document.createElement("button");
      removeButton.type = "button";
      removeButton.className = "remove-availability";
      removeButton.textContent = "\u00d7";
      removeButton.setAttribute("data-value", value);
      removeButton.setAttribute("aria-label", `Remove ${value}`);
      tag.appendChild(removeButton);

      availabilityTags.appendChild(tag);
    });
  };
  const updateAvailabilityUI = () => {
    syncAvailabilitySelect();
    renderAvailabilityTags();
    syncAvailabilityButtons();
  };
  const initializeSelectedAvailabilityFromSelect = () => {
    if (!availabilitySelect) return;
    selectedAvailability = new Set(
      Array.from(availabilitySelect.selectedOptions).map((option) => option.value)
    );
    updateAvailabilityUI();
  };
  const setIdCardModalState = (isOpen) => {
    if (!idCardModal) return;
    idCardModal.classList.toggle("is-open", Boolean(isOpen));
    idCardModal.setAttribute("aria-hidden", isOpen ? "false" : "true");
    document.body.style.overflow = isOpen ? "hidden" : "";
  };

  if (editButton) {
    editButton.addEventListener("click", () => {
      shell.classList.toggle("is-editing");
      editButton.textContent = shell.classList.contains("is-editing") ? "Editing" : "Edit Profile";
      if (shell.classList.contains("is-editing")) {
        initializeSelectedSkillsFromSelect();
        initializeSelectedAvailabilityFromSelect();
      } else if (skillSearchInput) {
        skillSearchInput.value = "";
      }
    });
  }
  if (viewIdCardButton) {
    viewIdCardButton.addEventListener("click", () => {
      setIdCardModalState(true);
    });
  }
  if (closeIdCardButton) {
    closeIdCardButton.addEventListener("click", () => {
      setIdCardModalState(false);
    });
  }
  if (idCardModal) {
    idCardModal.addEventListener("click", (event) => {
      if (event.target === idCardModal) {
        setIdCardModalState(false);
      }
    });
  }
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      setIdCardModalState(false);
    }
  });
  if (cancelButton) {
    cancelButton.addEventListener("click", () => {
      window.location.reload();
    });
  }

  if (skillSearchInput && skillSelect && skillsDropdown && selectedSkillsContainer) {
    skillSearchInput.addEventListener("input", renderSkillsDropdown);
    initializeSelectedSkillsFromSelect();
  }
  if (availabilitySelect && availabilityTags) {
    availabilityOptionButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const value = String(button.textContent || "").trim();
        if (!value) return;
        if (selectedAvailability.has(value)) {
          selectedAvailability.delete(value);
        } else {
          selectedAvailability.add(value);
        }
        updateAvailabilityUI();
      });
    });

    availabilityTags.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (!target.classList.contains("remove-availability")) return;
      const value = String(target.getAttribute("data-value") || "").trim();
      if (!value || !selectedAvailability.has(value)) return;
      selectedAvailability.delete(value);
      updateAvailabilityUI();
    });

    initializeSelectedAvailabilityFromSelect();
  }
  if (profileForm) {
    profileForm.addEventListener("submit", () => {
      if (skillSelect) updateHiddenSelect();
      if (availabilitySelect) syncAvailabilitySelect();
    });
  }

  assetTriggers.forEach((button) => {
    button.addEventListener("click", () => {
      const fieldName = String(button.getAttribute("data-asset-trigger") || "").trim();
      if (qualificationNameInput instanceof HTMLInputElement) {
        qualificationNameInput.value = "";
      }
      let input = null;
      if (fieldName === "profileImage") {
        input = assetProfileInput;
      } else if (fieldName === "aadhaarFront") {
        input = assetAadhaarFrontInput;
      } else if (fieldName === "aadhaarBack") {
        input = assetAadhaarBackInput;
      }
      if (!(input instanceof HTMLInputElement)) return;
      input.value = "";
      input.click();
    });
  });

  [assetProfileInput, assetAadhaarFrontInput, assetAadhaarBackInput].forEach((input) => {
    if (!(input instanceof HTMLInputElement) || !assetForm) return;
    input.addEventListener("change", () => {
      if (input.files && input.files.length > 0) {
        assetForm.submit();
      }
    });
  });
})();
// 🔥 FINAL FIX: AUTO SUBMIT FILE UPLOAD

</script>
